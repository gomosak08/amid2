<style>
  .home-wrap{
    padding: .35rem 0 2rem;
    background:
      radial-gradient(circle at top, rgba(219,234,254,.55), transparent 35%),
      linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  }

  .home-container{
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
  }

  .hero-main{
    position: relative;
    overflow: hidden;
    border-radius: 30px;
    background:
      linear-gradient(135deg, rgba(14,165,233,.98) 0%, rgba(37,99,235,.98) 55%, rgba(29,78,216,.98) 100%);
    box-shadow: 0 18px 45px rgba(37,99,235,.14);
    color: #fff;
    margin-bottom: 1.5rem;
  }

  .hero-main::before{
    content:"";
    position:absolute;
    inset:0;
    background:
      radial-gradient(circle at 12% 18%, rgba(255,255,255,.18), transparent 24%),
      radial-gradient(circle at 88% 22%, rgba(255,255,255,.12), transparent 20%),
      linear-gradient(120deg, rgba(255,255,255,.06), transparent 35%);
    pointer-events:none;
  }

  .hero-grid{
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(340px, .92fr);
    gap: 1.5rem;
    align-items: center;
    padding: clamp(1.25rem, 3vw, 2.5rem);
  }

  .hero-copy{
    max-width: 760px;
  }

  .hero-pill{
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    padding: .62rem .95rem;
    border-radius: 999px;
    font-size: .82rem;
    font-weight: 900;
    background: rgba(255,255,255,.14);
    border: 1px solid rgba(255,255,255,.22);
    backdrop-filter: blur(10px);
    margin-bottom: 1rem;
  }

  .hero-title{
    margin: 0 0 .85rem;
    font-size: clamp(2.1rem, 4vw, 4rem);
    line-height: .98;
    letter-spacing: -.03em;
    font-weight: 950;
  }

  .hero-text{
    margin: 0 0 1.2rem;
    max-width: 60ch;
    font-size: clamp(1rem, 1.2vw, 1.1rem);
    line-height: 1.7;
    color: rgba(255,255,255,.95);
  }

  .hero-actions{
    display:flex;
    flex-wrap:wrap;
    gap:.8rem;
    margin-bottom:1.15rem;
  }

  .hero-btn-primary,
  .hero-btn-secondary{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:.65rem;
    padding:.95rem 1.15rem;
    border-radius:16px;
    text-decoration:none;
    font-weight:900;
    transition: transform .18s ease, background .18s ease, border-color .18s ease, box-shadow .18s ease;
  }

  .hero-btn-primary{
    background:#22c55e;
    color:#06240f;
    box-shadow:0 14px 28px rgba(34,197,94,.24);
  }

  .hero-btn-primary:hover{
    transform: translateY(-2px);
    color:#06240f;
    background:#20b857;
  }

  .hero-btn-secondary{
    background: rgba(255,255,255,.12);
    color:#fff;
    border:1px solid rgba(255,255,255,.24);
    backdrop-filter: blur(8px);
  }

  .hero-btn-secondary:hover{
    transform: translateY(-2px);
    color:#fff;
    background: rgba(255,255,255,.18);
  }

  .hero-metrics{
    display:grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap:.8rem;
    max-width: 820px;
  }

  .hero-metric{
    padding: .95rem 1rem;
    border-radius: 18px;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.16);
    backdrop-filter: blur(10px);
  }

  .hero-metric strong{
    display:block;
    margin-bottom:.2rem;
    font-size:1rem;
    font-weight:900;
  }

  .hero-metric span{
    font-size:.92rem;
    color:rgba(255,255,255,.92);
    line-height:1.45;
  }

  .hero-visual{
    display:flex;
    align-items:center;
    justify-content:center;
  }

  .hero-visual-shell{
    width:100%;
    max-width: 560px;
    border-radius: 28px;
    padding: .9rem;
    background: rgba(255,255,255,.12);
    border:1px solid rgba(255,255,255,.20);
    backdrop-filter: blur(12px);
    box-shadow: 0 18px 34px rgba(15,23,42,.18);
  }

  .hero-carousel-card{
    overflow:hidden;
    border-radius: 22px;
    background: rgba(255,255,255,.10);
  }

  .hero-slide{
    position:relative;
    height: clamp(290px, 38vw, 450px);
    background:#dbeafe;
  }

  .hero-slide img{
    width:100%;
    height:100%;
    object-fit:cover;
    display:block;
  }

  .carousel-indicators{
    margin-bottom: .7rem;
  }

  .carousel-indicators [data-bs-target]{
    width:10px;
    height:10px;
    border-radius:999px;
    border:none;
    background:#dbeafe;
    opacity:.85;
    margin:0 5px;
  }

  .carousel-indicators .active{
    background:#22c55e !important;
    opacity:1;
  }

  .carousel-control-prev,
  .carousel-control-next{
    width: 2.7rem;
    height: 2.7rem;
    top: 50%;
    transform: translateY(-50%);
    margin: 0 .75rem;
    border-radius: 999px;
    background: rgba(255,255,255,.84);
  }

  .carousel-control-prev-icon,
  .carousel-control-next-icon{
    background-image:none;
    width:0;
    height:0;
  }

  .carousel-control-prev-icon{
    border-top:9px solid transparent;
    border-bottom:9px solid transparent;
    border-right:14px solid #111827;
  }

  .carousel-control-next-icon{
    border-top:9px solid transparent;
    border-bottom:9px solid transparent;
    border-left:14px solid #111827;
  }

  .search-section{
    margin-bottom: 1.4rem;
  }

  .search-card{
    background:#fff;
    border:1px solid #e2e8f0;
    border-radius: 24px;
    padding: 1rem;
    box-shadow: 0 14px 34px rgba(15,23,42,.06);
  }

  .search-top{
    display:grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: .9rem;
    align-items:center;
  }

  .search-input-wrap{
    position:relative;
  }

  .search-input-icon{
    position:absolute;
    left:16px;
    top:50%;
    transform:translateY(-50%);
    color:#64748b;
    font-size:1rem;
  }

  .search-input{
    width:100%;
    border:1px solid #dbe3ee;
    background:#f8fafc;
    border-radius:16px;
    padding:1rem 1rem 1rem 2.85rem;
    font-size:1rem;
    color:#0f172a;
    outline:none;
    transition: border-color .18s ease, box-shadow .18s ease, background .18s ease;
  }

  .search-input:focus{
    border-color:#93c5fd;
    background:#fff;
    box-shadow: 0 0 0 4px rgba(59,130,246,.10);
  }

  .search-button{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:.55rem;
    padding: 1rem 1.15rem;
    border-radius:16px;
    background:#2563eb;
    color:#fff;
    font-weight:900;
    text-decoration:none;
    border:none;
    white-space:nowrap;
    transition: background .18s ease, transform .18s ease;
  }

  .search-button:hover{
    background:#1d4ed8;
    color:#fff;
    transform: translateY(-1px);
  }

  .chip-row{
    display:flex;
    flex-wrap:wrap;
    gap:.75rem;
    margin-top: .95rem;
  }

  .quick-chip{
    display:inline-flex;
    align-items:center;
    gap:.55rem;
    padding:.78rem 1rem;
    border-radius:999px;
    text-decoration:none;
    font-weight:800;
    background:#f8fafc;
    color:#1e3a8a;
    border:1px solid #e2e8f0;
    transition: transform .18s ease, background .18s ease, border-color .18s ease;
  }

  .quick-chip:hover{
    transform: translateY(-1px);
    background:#eff6ff;
    color:#1d4ed8;
    border-color:#bfdbfe;
  }

  .selection-block,
  .section-block{
    scroll-margin-top: 120px;
  }

  .selection-block{
    margin-bottom: 1.6rem;
  }

  .section-block{
    margin-top: 1.5rem;
  }

  .section-head{
    display:flex;
    align-items:end;
    justify-content:space-between;
    gap:1rem;
    flex-wrap:wrap;
    margin-bottom: 1rem;
  }

  .section-kicker{
    display:inline-flex;
    align-items:center;
    gap:.5rem;
    font-size:.8rem;
    font-weight:900;
    letter-spacing:.05em;
    text-transform:uppercase;
    color:#2563eb;
    margin-bottom:.35rem;
  }

  .section-title{
    margin:0;
    font-size: clamp(1.55rem, 2vw, 2.1rem);
    font-weight:950;
    line-height:1.05;
    color:#0f172a;
  }

  .section-sub{
    margin:.38rem 0 0;
    color:#64748b;
    font-size:.97rem;
    line-height:1.65;
  }

  .section-link{
    display:inline-flex;
    align-items:center;
    gap:.5rem;
    text-decoration:none;
    font-weight:900;
    color:#2563eb;
  }

  .section-link:hover{
    color:#1d4ed8;
  }

  .selection-shell{
    background:#fff;
    border:1px solid #e2e8f0;
    border-radius:26px;
    padding:1.1rem;
    box-shadow: 0 12px 28px rgba(15,23,42,.05);
  }

  .selection-grid{
    display:grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap:1rem;
  }

  .selection-option{
    display:flex;
    flex-direction:column;
    gap:.8rem;
    padding:1.15rem;
    border-radius:22px;
    border:1px solid #e2e8f0;
    background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    text-decoration:none;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }

  .selection-option:hover{
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(15,23,42,.08);
    border-color:#93c5fd;
  }

  .selection-icon{
    width:56px;
    height:56px;
    border-radius:18px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    background:#eff6ff;
    color:#1d4ed8;
    font-size:1.25rem;
  }

  .selection-option h3{
    margin:0;
    font-size:1.06rem;
    font-weight:900;
    color:#0f172a;
  }

  .selection-option p{
    margin:0;
    color:#64748b;
    line-height:1.6;
  }

  .cards-grid{
    display:grid;
    gap:1.25rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .home-search-item.search-item-hidden{
    display:none !important;
  }

  .empty-search,
  .empty-state{
    background:#fff;
    border:1px dashed #cbd5e1;
    border-radius:22px;
    padding:1.2rem;
    text-align:center;
    color:#64748b;
  }

  .empty-search{
    display:none;
    margin-top:1.2rem;
  }

  .empty-search.is-visible{
    display:block;
  }

  @media (max-width: 1400px){
    .cards-grid{
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 1120px){
    .hero-grid{
      grid-template-columns: 1fr;
    }

    .hero-copy{
      max-width:none;
    }

    .hero-metrics{
      grid-template-columns: 1fr;
      max-width:none;
    }

    .selection-grid{
      grid-template-columns: 1fr;
    }

    .cards-grid{
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px){
    .hero-main{
      border-radius:22px;
    }

    .hero-grid{
      padding:1rem;
      gap:1rem;
    }

    .hero-title{
      font-size: 2rem;
    }

    .hero-actions{
      flex-direction:column;
    }

    .hero-btn-primary,
    .hero-btn-secondary{
      width:100%;
    }

    .search-card{
      border-radius:20px;
      padding:.9rem;
    }

    .search-top{
      grid-template-columns: 1fr;
    }

    .cards-grid,
    .selection-grid{
      grid-template-columns:1fr;
    }

    .section-head{
      align-items:start;
    }
  }
</style>

<%
  featured_services  = @packages.where(kind: "servicios", featured: true)
  featured_packages  = @packages.where(kind: "paquete", featured: true)
  featured_surgeries = @packages.where(kind: "cirugia", featured: true)
%>

<div class="home-wrap">
  <div class="home-container">

    <section class="hero-main">
      <div class="hero-grid">
        <div class="hero-copy">
          <span class="hero-pill">
            <i class="fa-solid fa-heart-pulse"></i>
            Atención médica profesional y confiable
          </span>

          <h1 class="hero-title">Encuentra tu servicio y agenda sin complicaciones</h1>

          <p class="hero-text">
            Elige primero el servicio o paquete que necesitas. Después continúa con una agenda
            más clara, con la opción correcta ya seleccionada.
          </p>

          <div class="hero-actions">
            <%= link_to "#seleccionar-agenda", class: "hero-btn-primary" do %>
              <i class="fa-solid fa-calendar-check"></i>
              Empezar ahora
            <% end %>

            <%= link_to "#servicios", class: "hero-btn-secondary" do %>
              <i class="fa-solid fa-stethoscope"></i>
              Explorar servicios
            <% end %>
          </div>

          <div class="hero-metrics">
            <div class="hero-metric">
              <strong>Eliges primero</strong>
              <span>Selecciona exactamente lo que deseas agendar antes de pasar al formulario.</span>
            </div>

            <div class="hero-metric">
              <strong>Agenda más clara</strong>
              <span>El sistema ya sabe qué opción elegiste para mostrarte el flujo correcto.</span>
            </div>

            <div class="hero-metric">
              <strong>Todo en una sola vista</strong>
              <span>Busca, compara y entra directo a la opción que te interesa.</span>
            </div>
          </div>
        </div>

        <div class="hero-visual">
          <div class="hero-visual-shell">
            <div class="hero-carousel-card">
              <div id="carouselExample" class="carousel slide" data-bs-ride="carousel" data-bs-interval="4500">
                <div class="carousel-indicators">
                  <% 5.times do |i| %>
                    <button type="button"
                            data-bs-target="#carouselExample"
                            data-bs-slide-to="<%= i %>"
                            class="<%= 'active' if i == 0 %>"
                            aria-label="Slide <%= i + 1 %>"></button>
                  <% end %>
                </div>

                <div class="carousel-inner">
                  <% ["slider1.jpg","slider2.jpg","slider3.jpg","slider4.jpg","slider5.jpg"].each_with_index do |img, idx| %>
                    <div class="carousel-item <%= 'active' if idx == 0 %>">
                      <div class="hero-slide">
                        <%= image_tag img, alt: "AMID", class: "w-full h-full object-cover" %>
                      </div>
                    </div>
                  <% end %>
                </div>

                <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
                  <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                  <span class="visually-hidden">Anterior</span>
                </button>

                <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
                  <span class="carousel-control-next-icon" aria-hidden="true"></span>
                  <span class="visually-hidden">Siguiente</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="search-section">
      <div class="search-card">
        <div class="search-top">
          <div class="search-input-wrap">
            <i class="fa-solid fa-magnifying-glass search-input-icon"></i>
            <input
              id="home-search-input"
              type="text"
              class="search-input"
              placeholder="Busca un servicio o paquete..."
              aria-label="Buscar servicios"
            >
          </div>

          <button id="home-search-clear" type="button" class="search-button">
            <i class="fa-solid fa-rotate-left"></i>
            Limpiar
          </button>
        </div>

        <div class="chip-row">
          <a href="#servicios" class="quick-chip">
            <i class="fa-solid fa-wave-square"></i>
            Servicios
          </a>

          <a href="#paquetes" class="quick-chip">
            <i class="fa-solid fa-box-open"></i>
            Paquetes
          </a>

          <%#
          <a href="#cirugias" class="quick-chip">
            <i class="fa-solid fa-user-doctor"></i>
            Cirugías
          </a>
          %>

          <a href="#seleccionar-agenda" class="quick-chip">
            <i class="fa-solid fa-calendar-plus"></i>
            Elegir para agendar
          </a>

          <%= link_to find_appointments_path, class: "quick-chip" do %>
            <i class="fa-solid fa-magnifying-glass-location"></i>
            Buscar cita
          <% end %>
        </div>
      </div>
    </section>

    <section class="selection-block" id="seleccionar-agenda">
      <div class="section-head">
        <div>
          <div class="section-kicker">
            <i class="fa-solid fa-calendar-check"></i>
            Agenda paso a paso
          </div>
          <h2 class="section-title">Selecciona qué deseas agendar</h2>
          <p class="section-sub">
            Empieza por la categoría y luego entra a la opción específica que necesitas.
          </p>
        </div>
      </div>

      <div class="selection-shell">
        <div class="selection-grid">
          <a href="#servicios" class="selection-option">
            <span class="selection-icon"><i class="fa-solid fa-stethoscope"></i></span>
            <h3>Servicios</h3>
            <p>Ultrasonidos, consultas y otros servicios médicos individuales.</p>
          </a>

          <a href="#paquetes" class="selection-option">
            <span class="selection-icon"><i class="fa-solid fa-box-open"></i></span>
            <h3>Paquetes</h3>
            <p>Opciones agrupadas para una atención más completa y práctica.</p>
          </a>

          <%#
          <a href="#cirugias" class="selection-option">
            <span class="selection-icon"><i class="fa-solid fa-user-doctor"></i></span>
            <h3>Cirugías</h3>
            <p>Procedimientos especializados con información clara y acceso directo.</p>
          </a>
          %>
        </div>
      </div>
    </section>

    <section class="section-block" id="servicios">
      <div class="section-head">
        <div>
          <div class="section-kicker">
            <i class="fa-solid fa-stethoscope"></i>
            Servicios destacados
          </div>
          <h2 class="section-title">Servicios médicos</h2>
          <p class="section-sub">
            Selecciona un servicio y agenda con esa opción ya elegida.
          </p>
        </div>

        <%= link_to services_path, class: "section-link" do %>
          Ver todos
          <i class="fa-solid fa-arrow-right"></i>
        <% end %>
      </div>

      <% if featured_services.any? %>
        <div class="cards-grid">
          <% featured_services.each do |package| %>
            <div
              class="home-search-item"
              data-search-text="<%= [package.name, package.description, package.kind, package.price, package.duration].compact.join(' ').downcase %>">
              <%= render "shared/featured_package_card", package: package %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">Aún no hay servicios destacados disponibles.</div>
      <% end %>
    </section>

    <section class="section-block" id="paquetes">
      <div class="section-head">
        <div>
          <div class="section-kicker">
            <i class="fa-solid fa-box-open"></i>
            Opciones recomendadas
          </div>
          <h2 class="section-title">Paquetes</h2>
          <p class="section-sub">
            Elige un paquete y continúa con la agenda ya precargada.
          </p>
        </div>

        <%= link_to packages_path, class: "section-link" do %>
          Ver todos
          <i class="fa-solid fa-arrow-right"></i>
        <% end %>
      </div>

      <% if featured_packages.any? %>
        <div class="cards-grid">
          <% featured_packages.each do |package| %>
            <div
              class="home-search-item"
              data-search-text="<%= [package.name, package.description, package.kind, package.price, package.duration].compact.join(' ').downcase %>">
              <%= render "shared/featured_package_card", package: package %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">Aún no hay paquetes destacados disponibles.</div>
      <% end %>
    </section>

    <%#
    <section class="section-block" id="cirugias">
      <div class="section-head">
        <div>
          <div class="section-kicker">
            <i class="fa-solid fa-user-doctor"></i>
            Atención especializada
          </div>
          <h2 class="section-title">Cirugías</h2>
          <p class="section-sub">
            Selecciona una cirugía y sigue con la agenda teniendo esa opción definida.
          </p>
        </div>

        <%= link_to surgeries_path, class: "section-link" do % >
          Ver todas
          <i class="fa-solid fa-arrow-right"></i>
        <% end % >
      </div>

      <% if featured_surgeries.any? % >
        <div class="cards-grid">
          <% featured_surgeries.each do |package| % >
            <div
              class="home-search-item"
              data-search-text="<%= [package.name, package.description, package.kind, package.price, package.duration].compact.join(' ').downcase % >">
              <%= render "shared/featured_package_card", package: package % >
            </div>
          <% end % >
        </div>
      <% else % >
        <div class="empty-state">Aún no hay cirugías destacadas disponibles.</div>
      <% end % >
    </section>
    %>

    <div id="home-search-empty" class="empty-search">
      No encontramos resultados con ese texto. Prueba con otro nombre o revisa las categorías.
    </div>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", function () {
    const input = document.getElementById("home-search-input");
    const clearBtn = document.getElementById("home-search-clear");
    const items = Array.from(document.querySelectorAll(".home-search-item"));
    const empty = document.getElementById("home-search-empty");

    if (!input || !clearBtn || items.length === 0) return;

    function normalize(text) {
      return (text || "")
        .toString()
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .trim();
    }

    function runSearch() {
      const term = normalize(input.value);
      let visibleCount = 0;

      items.forEach((item) => {
        const text = normalize(item.dataset.searchText);
        const matches = term === "" || text.includes(term);

        item.classList.toggle("search-item-hidden", !matches);
        if (matches) visibleCount += 1;
      });

      if (empty) {
        empty.classList.toggle("is-visible", term.length > 0 && visibleCount === 0);
      }
    }

    input.addEventListener("input", runSearch);

    clearBtn.addEventListener("click", function () {
      input.value = "";
      runSearch();
      input.focus();
    });

    runSearch();
  });
</script>