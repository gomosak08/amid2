<!-- app/views/admin/packages/_form.html.erb -->

<%= form_with(model: [:admin, @package], local: true, html: { multipart: true }, class: "bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden") do |form| %>
  <div class="px-5 py-6 sm:px-8 sm:py-8 border-b border-gray-100 bg-gradient-to-r from-blue-50 to-white">
    <h2 class="text-2xl font-bold text-gray-900">
      <%= @package.persisted? ? "Editar paquete" : "Nuevo paquete" %>
    </h2>
    <p class="mt-1 text-sm text-gray-600">
      Completa la información del paquete.
    </p>
  </div>

  <div class="p-5 sm:p-8 space-y-8">
    <% if @package.errors.any? %>
      <div id="error_explanation" class="rounded-xl border border-red-200 bg-red-50 p-4">
        <h2 class="text-sm font-semibold text-red-800 mb-2">
          <%= pluralize(@package.errors.count, "error") %> impidieron guardar este paquete:
        </h2>
        <ul class="list-disc pl-5 space-y-1 text-sm text-red-700">
          <% @package.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="lg:col-span-2">
        <%= form.label :name, "Nombre", class: "block text-sm font-semibold text-gray-800 mb-2" %>
        <%= form.text_field :name, class: "block w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div class="lg:col-span-2">
        <%= form.label :description, "Descripción", class: "block text-sm font-semibold text-gray-800 mb-2" %>
        <%= form.text_area :description, rows: 5, class: "block w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500 resize-y" %>
      </div>

      <div>
        <%= form.label :price, "Precio", class: "block text-sm font-semibold text-gray-800 mb-2" %>
        <%= form.number_field :price, step: 0.01, class: "block w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :duration, "Duración (minutos)", class: "block text-sm font-semibold text-gray-800 mb-2" %>
        <%= form.number_field :duration, class: "block w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div class="lg:col-span-2">
        <%= form.label :kind, "Tipo de paquete", class: "block text-sm font-semibold text-gray-800 mb-2" %>
        <%= form.select :kind,
            [["Servicios", "servicios"], ["Paquete", "paquete"], ["Cirugía", "cirugia"]],
            { prompt: "Selecciona un tipo" },
            class: "block w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500" %>
      </div>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-gray-50 p-4 sm:p-5">
      <label class="block text-sm font-semibold text-gray-800 mb-3">Imagen</label>

      <% if @package.image.attached? %>
        <p class="text-sm text-gray-600 mb-2">Imagen actual</p>
        <%= image_tag @package.image, class: "w-full max-w-xs h-52 object-cover rounded-xl border border-gray-200 bg-white mb-4" %>
      <% end %>

      <label for="customFileInput" class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 transition cursor-pointer">
        Seleccionar imagen
      </label>

      <%= form.file_field :image, id: "customFileInput", class: "hidden" %>

      <p class="mt-3 text-sm text-gray-500">
        Si dejas este campo vacío, se conservará la imagen actual.
      </p>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white p-4 sm:p-5">
      <div class="flex items-start gap-3">
        <div class="pt-0.5">
          <%= form.check_box :featured, class: "h-5 w-5 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
        </div>
        <div>
          <%= form.label :featured, "Mostrar en página principal", class: "text-sm font-semibold text-gray-800" %>
        </div>
      </div>
    </div>

    <div>
      <%= form.label :doctor_ids, "Doctores que pueden dar este servicio", class: "block text-sm font-semibold text-gray-800 mb-3" %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <% Doctor.order(:name).each do |doctor| %>
          <label class="flex items-center gap-3 rounded-xl border border-gray-200 bg-white px-4 py-3 hover:border-blue-300 hover:bg-blue-50 cursor-pointer">
            <%= check_box_tag "package[doctor_ids][]",
                doctor.id,
                @package.doctor_ids.include?(doctor.id),
                id: "package_doctor_ids_#{doctor.id}",
                class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
            <span class="text-sm font-medium text-gray-700"><%= doctor.name %></span>
          </label>
        <% end %>
      </div>
    </div>
  </div>

  <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 px-5 py-5 sm:px-8 border-t border-gray-100 bg-gray-50">
    <%= link_to "Cancelar",
        admin_packages_path,
        class: "inline-flex items-center justify-center rounded-xl border border-gray-300 bg-white px-5 py-3 text-sm font-semibold text-gray-700 hover:bg-gray-100 transition" %>

    <%= form.submit (@package.persisted? ? "Actualizar paquete" : "Guardar paquete"),
        class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 transition" %>
  </div>
<% end %>