<% status_options = [
  ["Programada", "scheduled"],
  ["Completada", "completed"],
  ["Cancelada por admin", "canceled_by_admin"],
  ["Cancelada por cliente", "canceled_by_client"],
  ["No asistió", "no_show"]
] %>

<div class="min-h-[80vh] bg-[linear-gradient(180deg,_#f8fbff_0%,_#ffffff_42%,_#f8fafc_100%)]">
  <div class="mx-auto w-full max-w-[1500px] px-4 py-8 sm:px-6 lg:px-8">
    <section class="mb-6 overflow-hidden rounded-[30px] border border-slate-200 bg-white shadow-xl shadow-sky-100/50">
      <div class="bg-[radial-gradient(circle_at_top_left,_rgba(125,211,252,0.24),_transparent_28%),linear-gradient(135deg,_#0f172a_0%,_#1d4ed8_58%,_#0891b2_100%)] px-6 py-8 text-white sm:px-8 sm:py-9">
        <div class="flex flex-col gap-6 2xl:flex-row 2xl:items-end 2xl:justify-between">
          <div class="max-w-4xl">
            <span class="inline-flex items-center rounded-full bg-white/12 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-white/85">
              Estadísticas administrativas
            </span>
            <h1 class="mt-4 text-3xl font-black tracking-tight sm:text-4xl">
              Resumen de agenda y operación
            </h1>
            <p class="mt-3 max-w-3xl text-sm leading-6 text-blue-50 sm:text-base">
              Revisa qué pasó con las citas en el periodo elegido, quién las registró y cómo se distribuyó la carga de atención por médico.
            </p>
          </div>

          <div class="grid grid-cols-2 gap-3 sm:grid-cols-4 xl:min-w-[520px]">
            <div class="rounded-2xl border border-white/15 bg-white/10 p-4 backdrop-blur">
              <div class="text-xs font-semibold uppercase tracking-[0.14em] text-white/70">Total</div>
              <div class="mt-2 text-2xl font-black"><%= @summary[:total] %></div>
            </div>

            <div class="rounded-2xl border border-white/15 bg-white/10 p-4 backdrop-blur">
              <div class="text-xs font-semibold uppercase tracking-[0.14em] text-white/70">Completadas</div>
              <div class="mt-2 text-2xl font-black"><%= @summary[:completed] %></div>
            </div>

            <div class="rounded-2xl border border-white/15 bg-white/10 p-4 backdrop-blur">
              <div class="text-xs font-semibold uppercase tracking-[0.14em] text-white/70">Canceladas</div>
              <div class="mt-2 text-2xl font-black"><%= @summary[:canceled] %></div>
            </div>

            <div class="rounded-2xl border border-white/15 bg-white/10 p-4 backdrop-blur">
              <div class="text-xs font-semibold uppercase tracking-[0.14em] text-white/70">Periodo</div>
              <div class="mt-2 text-sm font-bold leading-5">
                <%= l(@from, format: "%d/%m/%Y") %><br>
                <%= l(@to, format: "%d/%m/%Y") %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mb-6 overflow-hidden rounded-[30px] border border-slate-200 bg-white shadow-lg shadow-slate-200/60">
      <div class="border-b border-slate-100 px-6 py-5 sm:px-8">
        <div class="flex flex-col gap-2 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <h2 class="text-xl font-black text-slate-900">Filtros</h2>
            <p class="mt-1 text-sm text-slate-500">
              Todo está arriba para que no se pierda espacio horizontal en los resultados.
            </p>
          </div>

          <div class="text-sm text-slate-500">
            <strong class="text-slate-700">Citas creadas por usuario:</strong> se calculan con `created_by`, así que cada asistente está contando bien sus propias citas.
          </div>
        </div>
      </div>

      <div class="px-6 py-6 sm:px-8">
        <%= form_with url: admin_statistics_path, method: :get, local: true, class: "space-y-5" do %>
          <div class="grid grid-cols-1 gap-5 xl:grid-cols-4">
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
              <div class="mb-3 text-sm font-bold uppercase tracking-[0.16em] text-slate-500">Rango</div>
              <div class="grid grid-cols-1 gap-3">
                <div>
                  <label class="mb-2 block text-sm font-semibold text-slate-700">Desde</label>
                  <%= date_field_tag :from, @from, class: "block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-700 shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20" %>
                </div>
                <div>
                  <label class="mb-2 block text-sm font-semibold text-slate-700">Hasta</label>
                  <%= date_field_tag :to, @to, class: "block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-700 shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20" %>
                </div>
              </div>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
              <div class="mb-3 text-sm font-bold uppercase tracking-[0.16em] text-slate-500">Médicos</div>
              <div class="grid max-h-52 gap-2 overflow-y-auto pr-1">
                <% @doctor_options.each do |doctor| %>
                  <% checked = Array(params[:doctor_ids]).map(&:to_s).include?(doctor.id.to_s) %>
                  <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-slate-200 bg-white px-3 py-2.5 transition hover:border-blue-300 hover:bg-blue-50">
                    <%= check_box_tag "doctor_ids[]", doctor.id, checked, class: "mt-1 h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" %>
                    <span class="text-sm font-semibold text-slate-800"><%= doctor.name %></span>
                  </label>
                <% end %>
              </div>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
              <div class="mb-3 text-sm font-bold uppercase tracking-[0.16em] text-slate-500">Agendada por</div>
              <div class="grid max-h-52 gap-2 overflow-y-auto pr-1">
                <% checked = Array(params[:creator_filters]).include?("patient") %>
                <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-slate-200 bg-white px-3 py-2.5 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">
                  <%= check_box_tag "creator_filters[]", "patient", checked, class: "mt-1 h-4 w-4 rounded border-slate-300 text-fuchsia-600 focus:ring-fuchsia-500" %>
                  <span class="text-sm font-semibold text-slate-800">Paciente / sin usuario</span>
                </label>

                <% @creator_options.each do |creator| %>
                  <% checked = Array(params[:creator_filters]).include?("user:#{creator.id}") %>
                  <% creator_role = creator.role == "doctor" ? "Médico" : (creator.role == "admin" ? "Admin" : "Asistente") %>
                  <% creator_name = creator.try(:name).presence || creator.email.to_s.split("@").first %>
                  <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-slate-200 bg-white px-3 py-2.5 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">
                    <%= check_box_tag "creator_filters[]", "user:#{creator.id}", checked, class: "mt-1 h-4 w-4 rounded border-slate-300 text-fuchsia-600 focus:ring-fuchsia-500" %>
                    <span class="text-sm font-semibold text-slate-800"><%= "#{creator_role} - #{creator_name}" %></span>
                  </label>
                <% end %>
              </div>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
              <div class="mb-3 text-sm font-bold uppercase tracking-[0.16em] text-slate-500">Estados y paquetes</div>

              <div class="space-y-4">
                <div>
                  <div class="mb-2 text-xs font-bold uppercase tracking-[0.14em] text-slate-400">Estados</div>
                  <div class="grid gap-2">
                    <% status_options.each do |label_text, value| %>
                      <% checked = Array(params[:statuses]).include?(value) %>
                      <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-slate-200 bg-white px-3 py-2.5 transition hover:border-emerald-300 hover:bg-emerald-50">
                        <%= check_box_tag "statuses[]", value, checked, class: "mt-1 h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" %>
                        <span class="text-sm font-semibold text-slate-800"><%= label_text %></span>
                      </label>
                    <% end %>
                  </div>
                </div>

                <div>
                  <div class="mb-2 text-xs font-bold uppercase tracking-[0.14em] text-slate-400">Paquetes</div>
                  <div class="grid max-h-40 gap-2 overflow-y-auto pr-1">
                    <% @package_options.each do |package| %>
                      <% checked = Array(params[:package_ids]).map(&:to_s).include?(package.id.to_s) %>
                      <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-slate-200 bg-white px-3 py-2.5 transition hover:border-amber-300 hover:bg-amber-50">
                        <%= check_box_tag "package_ids[]", package.id, checked, class: "mt-1 h-4 w-4 rounded border-slate-300 text-amber-600 focus:ring-amber-500" %>
                        <div>
                          <div class="text-sm font-semibold text-slate-800"><%= package.name %></div>
                          <div class="mt-1 text-xs text-slate-500"><%= package.kind.to_s.humanize %></div>
                        </div>
                      </label>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-3 border-t border-slate-100 pt-5 sm:flex-row sm:justify-end">
            <%= link_to "Limpiar filtros", admin_statistics_path, class: "inline-flex items-center justify-center rounded-2xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
            <%= submit_tag "Aplicar filtros", class: "inline-flex items-center justify-center rounded-2xl bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700" %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="mb-6 grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-4">
      <article class="rounded-[26px] border border-slate-200 bg-white p-6 shadow-lg shadow-slate-200/50">
        <div class="text-xs font-bold uppercase tracking-[0.16em] text-slate-400">Programadas</div>
        <div class="mt-3 text-4xl font-black text-blue-700"><%= @summary[:scheduled] %></div>
        <p class="mt-2 text-sm text-slate-500">Pendientes dentro del periodo filtrado.</p>
      </article>

      <article class="rounded-[26px] border border-slate-200 bg-white p-6 shadow-lg shadow-slate-200/50">
        <div class="text-xs font-bold uppercase tracking-[0.16em] text-slate-400">Completadas</div>
        <div class="mt-3 text-4xl font-black text-emerald-700"><%= @summary[:completed] %></div>
        <p class="mt-2 text-sm text-slate-500">Sí fueron atendidas.</p>
      </article>

      <article class="rounded-[26px] border border-slate-200 bg-white p-6 shadow-lg shadow-slate-200/50">
        <div class="text-xs font-bold uppercase tracking-[0.16em] text-slate-400">Canceladas</div>
        <div class="mt-3 text-4xl font-black text-rose-700"><%= @summary[:canceled] %></div>
        <p class="mt-2 text-sm text-slate-500">Cliente o administración.</p>
      </article>

      <article class="rounded-[26px] border border-slate-200 bg-white p-6 shadow-lg shadow-slate-200/50">
        <div class="text-xs font-bold uppercase tracking-[0.16em] text-slate-400">No show</div>
        <div class="mt-3 text-4xl font-black text-amber-700"><%= @summary[:no_show] %></div>
        <p class="mt-2 text-sm text-slate-500">Pacientes que no asistieron.</p>
      </article>
    </section>

    <section class="grid grid-cols-1 gap-6 2xl:grid-cols-2">
      <article class="overflow-hidden rounded-[30px] border border-slate-200 bg-white shadow-lg shadow-slate-200/60">
        <div class="border-b border-slate-100 px-6 py-5 sm:px-8">
          <h2 class="text-xl font-black text-slate-900">Citas creadas por usuario</h2>
          <p class="mt-1 text-sm text-slate-500">
            Sección enfocada en operación interna: quién está registrando más citas y cómo avanzan.
          </p>
        </div>

        <div class="px-6 py-4 sm:px-8">
          <% if @appointments_by_creator.any? %>
            <div class="overflow-hidden rounded-[24px] border border-slate-200">
              <table class="min-w-full">
                <thead class="bg-slate-50">
                  <tr>
                    <th class="px-5 py-4 text-left text-xs font-bold uppercase tracking-[0.16em] text-slate-500">Usuario</th>
                    <th class="px-5 py-4 text-left text-xs font-bold uppercase tracking-[0.16em] text-slate-500">Total</th>
                    <th class="px-5 py-4 text-left text-xs font-bold uppercase tracking-[0.16em] text-slate-500">Programadas</th>
                    <th class="px-5 py-4 text-left text-xs font-bold uppercase tracking-[0.16em] text-slate-500">Completadas</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 bg-white">
                  <% @appointments_by_creator.each do |row| %>
                    <tr class="hover:bg-slate-50/80">
                      <td class="px-5 py-4 text-sm font-semibold text-slate-800"><%= row[:creator_label] %></td>
                      <td class="px-5 py-4 text-sm font-black text-slate-900"><%= row[:total] %></td>
                      <td class="px-5 py-4 text-sm text-blue-700"><%= row[:scheduled] %></td>
                      <td class="px-5 py-4 text-sm text-emerald-700"><%= row[:completed] %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="rounded-3xl border border-dashed border-slate-300 bg-slate-50 px-6 py-12 text-center text-slate-500">
              No hay creadores que coincidan con el filtro actual.
            </div>
          <% end %>
        </div>
      </article>

      <article class="overflow-hidden rounded-[30px] border border-slate-200 bg-white shadow-lg shadow-slate-200/60">
        <div class="border-b border-slate-100 px-6 py-5 sm:px-8">
          <h2 class="text-xl font-black text-slate-900">Desempeño por médico</h2>
          <p class="mt-1 text-sm text-slate-500">
            Panorama más compacto para comparar rápidamente actividad y resultado.
          </p>
        </div>

        <div class="px-6 py-4 sm:px-8">
          <% if @appointments_by_doctor.any? %>
            <div class="overflow-hidden rounded-[24px] border border-slate-200">
              <table class="min-w-full">
                <thead class="bg-slate-50">
                  <tr>
                    <th class="px-5 py-4 text-left text-xs font-bold uppercase tracking-[0.16em] text-slate-500">Médico</th>
                    <th class="px-5 py-4 text-left text-xs font-bold uppercase tracking-[0.16em] text-slate-500">Total</th>
                    <th class="px-5 py-4 text-left text-xs font-bold uppercase tracking-[0.16em] text-slate-500">Completadas</th>
                    <th class="px-5 py-4 text-left text-xs font-bold uppercase tracking-[0.16em] text-slate-500">Canceladas</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 bg-white">
                  <% @appointments_by_doctor.each do |row| %>
                    <tr class="hover:bg-slate-50/80">
                      <td class="px-5 py-4 text-sm font-semibold text-slate-800"><%= row[:doctor_name] %></td>
                      <td class="px-5 py-4 text-sm font-black text-slate-900"><%= row[:total] %></td>
                      <td class="px-5 py-4 text-sm text-emerald-700"><%= row[:completed] %></td>
                      <td class="px-5 py-4 text-sm text-rose-700"><%= row[:canceled] %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="rounded-3xl border border-dashed border-slate-300 bg-slate-50 px-6 py-12 text-center text-slate-500">
              No hay datos de médicos para ese filtro.
            </div>
          <% end %>
        </div>
      </article>
    </section>
  </div>
</div>
