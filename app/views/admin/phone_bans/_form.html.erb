<div class="rounded-2xl border border-gray-200 bg-white shadow-sm p-6">
  <%= form_with model: [:admin, @phone_ban], local: true do |f| %>
    <% if @phone_ban.errors.any? %>
      <div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3">
        <p class="font-semibold text-red-800 mb-2">No se pudo guardar el baneo:</p>
        <ul class="list-disc pl-5 text-sm text-red-700 space-y-1">
          <% @phone_ban.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div class="md:col-span-2">
        <%= label_tag :phone, "Número de teléfono", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= text_field_tag "phone_ban[phone]",
          @phone_ban.phone_e164,
          placeholder: "Ej. 5512345678 o +525512345678",
          class: "w-full rounded-lg border border-gray-300 px-4 py-3 focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= f.label :level, "Nivel de baneo", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :level,
          [["Parcial (solo bloquea agendado en línea)", "soft"], ["Total (bloquea agendado y contacto)", "hard"]],
          {},
          class: "w-full rounded-lg border border-gray-300 px-4 py-3 focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= f.label :active, "Estado", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :active,
          [["Activo", true], ["Inactivo", false]],
          {},
          class: "w-full rounded-lg border border-gray-300 px-4 py-3 focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= f.label :expires_at, "Expira en", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.datetime_local_field :expires_at,
          value: (@phone_ban.expires_at&.strftime("%Y-%m-%dT%H:%M")),
          class: "w-full rounded-lg border border-gray-300 px-4 py-3 focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div class="md:col-span-2">
        <%= f.label :reason, "Motivo", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :reason,
          rows: 5,
          class: "w-full rounded-lg border border-gray-300 px-4 py-3 focus:border-blue-500 focus:ring-blue-500" %>
      </div>
    </div>

    <div class="mt-6 flex items-center justify-end gap-3">
      <%= link_to "Cancelar", admin_phone_bans_path,
        class: "inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-gray-700 font-semibold hover:bg-gray-50 transition" %>

      <%= f.submit (@phone_ban.persisted? ? "Actualizar baneo" : "Guardar baneo"),
        class: "inline-flex items-center justify-center rounded-lg bg-red-600 px-4 py-2 text-white font-semibold hover:bg-red-700 transition" %>
    </div>
  <% end %>
</div>