<div class="w-full py-10">
  <div class="flex items-center justify-between gap-4 flex-wrap mb-6">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Baneos de pacientes</h1>
      <p class="text-sm text-gray-600 mt-1">
        Administra números restringidos para agendar o contactar a un asistente.
      </p>
    </div>

    <div class="flex gap-2">
      <%= link_to "Nuevo baneo", new_admin_phone_ban_path,
        class: "inline-flex items-center justify-center rounded-lg bg-red-600 px-4 py-2 text-white font-semibold hover:bg-red-700 transition" %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="mb-4 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-green-800">
      <%= notice %>
    </div>
  <% end %>

  <% if alert.present? %>
    <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-800">
      <%= alert %>
    </div>
  <% end %>

  <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600">ID</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600">Teléfono</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600">Nivel</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600">Origen</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600">Motivo</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600">Estado</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600">Expira</th>
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-600">Acciones</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-100 bg-white">
          <% if @phone_bans.any? %>
            <% @phone_bans.each do |ban| %>
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-4 text-sm font-medium text-gray-700">#<%= ban.id %></td>
                <td class="px-4 py-4 text-sm font-semibold text-gray-900"><%= ban.phone_e164 %></td>

                <td class="px-4 py-4 text-sm">
                  <% if ban.hard? %>
                    <span class="inline-flex rounded-full bg-red-100 px-3 py-1 text-xs font-semibold text-red-700">Total</span>
                  <% else %>
                    <span class="inline-flex rounded-full bg-yellow-100 px-3 py-1 text-xs font-semibold text-yellow-700">Parcial</span>
                  <% end %>
                </td>

                <td class="px-4 py-4 text-sm">
                  <% if ban.manual? %>
                    <span class="inline-flex rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">Manual</span>
                  <% else %>
                    <span class="inline-flex rounded-full bg-purple-100 px-3 py-1 text-xs font-semibold text-purple-700">Automático</span>
                  <% end %>
                </td>

                <td class="px-4 py-4 text-sm text-gray-700"><%= ban.reason %></td>

                <td class="px-4 py-4 text-sm">
                  <% if ban.active_now? %>
                    <span class="inline-flex rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">Activo</span>
                  <% else %>
                    <span class="inline-flex rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-700">Inactivo</span>
                  <% end %>
                </td>

                <td class="px-4 py-4 text-sm text-gray-700">
                  <%= ban.expires_at.present? ? l(ban.expires_at, format: :long) : "Sin expiración" %>
                </td>

                <td class="px-4 py-4 text-sm">
                  <div class="flex flex-wrap justify-end gap-2">
                    <%= link_to "Editar",
                      edit_admin_phone_ban_path(ban),
                      class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-3 py-2 text-white text-sm font-semibold hover:bg-blue-700 transition" %>

                    <%= button_to ban.active? ? "Desactivar" : "Activar",
                      toggle_active_admin_phone_ban_path(ban),
                      method: :patch,
                      class: "inline-flex items-center justify-center rounded-lg bg-gray-900 px-3 py-2 text-white text-sm font-semibold hover:bg-black transition" %>

                    <%= button_to "Eliminar",
                      admin_phone_ban_path(ban),
                      method: :delete,
                      data: { turbo_confirm: "¿Seguro que deseas eliminar este baneo?" },
                      class: "inline-flex items-center justify-center rounded-lg bg-red-600 px-3 py-2 text-white text-sm font-semibold hover:bg-red-700 transition" %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="8" class="px-4 py-10 text-center text-sm text-gray-500">
                No hay números baneados registrados.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>