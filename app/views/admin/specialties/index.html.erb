<!-- app/views/admin/specialties/index.html.erb -->

<div class="w-full py-10">
  <% total_specialties = @specialties.size %>

  <!-- Mensajes Flash -->
  <% if notice.present? %>
    <div class="mb-6 rounded-2xl border border-green-200 bg-green-50 px-4 py-4 text-sm text-green-700 font-medium">
      <%= notice %>
    </div>
  <% end %>

  <!-- Encabezado -->
  <div class="relative overflow-hidden rounded-3xl bg-gradient-to-r from-slate-900 via-violet-800 to-purple-700 px-6 py-8 sm:px-8 sm:py-10 shadow-xl mb-8">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute -top-10 -right-10 h-40 w-40 rounded-full bg-white"></div>
      <div class="absolute bottom-0 left-0 h-28 w-28 rounded-full bg-white"></div>
    </div>

    <div class="relative flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
      <div class="max-w-2xl">
        <span class="inline-flex items-center rounded-full bg-white/15 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-violet-100 ring-1 ring-white/20">
          Panel administrativo
        </span>

        <h1 class="mt-3 text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-white">
          Especialidades Médicas
        </h1>

        <p class="mt-3 text-sm sm:text-base text-violet-100/90 leading-relaxed">
          Gestiona el catálogo de especialidades médicas disponibles en el sistema.
        </p>
      </div>

      <div class="w-full sm:w-auto">
        <%= link_to new_admin_specialty_path,
            class: "inline-flex w-full sm:w-auto items-center justify-center rounded-2xl bg-white px-5 py-3 text-sm font-semibold text-slate-900 shadow-lg transition hover:scale-[1.01] hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-violet-800" do %>
          <i class="fa-solid fa-plus mr-2"></i> Nueva Especialidad
        <% end %>
      </div>
    </div>
  </div>

  <!-- Estadísticas -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3 mb-8">
    <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-slate-500">Total de especialidades</p>
          <p class="mt-2 text-3xl font-bold tracking-tight text-slate-900"><%= total_specialties %></p>
          <p class="mt-1 text-sm text-slate-500">Registradas en el sistema</p>
        </div>
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-violet-50 text-violet-700 text-xl shadow-sm">
          🏥
        </div>
      </div>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-slate-500">Gestión rápida</p>
          <p class="mt-2 text-lg font-bold tracking-tight text-slate-900">
            Edita o elimina registros
          </p>
          <p class="mt-1 text-sm text-slate-500">Desde la tabla de abajo</p>
        </div>
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-amber-50 text-amber-700 text-xl shadow-sm">
          ⚙️
        </div>
      </div>
    </div>
  </div>

  <% if @specialties.any? %>
    <!-- Tabla Desktop -->
    <div class="hidden lg:block overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-200 bg-slate-50/80 px-6 py-4">
        <div class="flex items-center justify-between gap-4">
          <div>
            <h2 class="text-base font-semibold text-slate-900">Listado de especialidades</h2>
            <p class="text-sm text-slate-500">Vista general con acciones rápidas</p>
          </div>
          <span class="inline-flex items-center rounded-full bg-violet-100 px-3 py-1 text-xs font-semibold text-violet-800">
            <%= total_specialties %> registradas
          </span>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-slate-500">#</th>
              <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-slate-500">Nombre</th>
              <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-wider text-slate-500">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 bg-white">
            <% @specialties.each_with_index do |specialty, index| %>
              <tr class="transition hover:bg-slate-50/80">
                <td class="px-6 py-5 align-top">
                  <span class="inline-flex h-8 min-w-[2rem] items-center justify-center rounded-full bg-slate-100 px-2 text-xs font-bold text-slate-700">
                    <%= index + 1 %>
                  </span>
                </td>

                <td class="px-6 py-5 align-top">
                  <div class="flex items-center gap-3">
                    <span class="inline-flex rounded-full border border-violet-200 bg-violet-50 px-3 py-1 text-sm font-semibold text-violet-700">
                      <%= specialty.name %>
                    </span>
                  </div>
                </td>

                <td class="px-6 py-5 align-top">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to "Editar",
                        edit_admin_specialty_path(specialty),
                        class: "inline-flex items-center rounded-xl border border-blue-200 bg-blue-50 px-3.5 py-2 text-sm font-medium text-blue-700 transition hover:bg-blue-100" %>

                    <%= button_to "Eliminar",
                        admin_specialty_path(specialty),
                        method: :delete,
                        data: { turbo_confirm: "¿Estás seguro de eliminar la especialidad \"#{specialty.name}\"?" },
                        class: "inline-flex items-center rounded-xl border border-red-200 bg-red-50 px-3.5 py-2 text-sm font-medium text-red-700 transition hover:bg-red-100" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Tarjetas Mobile / Tablet -->
    <div class="grid grid-cols-1 gap-4 lg:hidden">
      <% @specialties.each_with_index do |specialty, index| %>
        <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition hover:shadow-md">
          <div class="bg-gradient-to-r from-slate-50 to-violet-50 px-4 py-4 border-b border-slate-200">
            <div class="flex items-center gap-3">
              <span class="inline-flex h-7 min-w-[1.75rem] items-center justify-center rounded-full bg-slate-900 px-2 text-xs font-bold text-white">
                <%= index + 1 %>
              </span>
              <h2 class="text-lg font-bold text-slate-900 break-words"><%= specialty.name %></h2>
            </div>
          </div>

          <div class="p-4 grid grid-cols-2 gap-2">
            <%= link_to "Editar",
                edit_admin_specialty_path(specialty),
                class: "inline-flex items-center justify-center rounded-2xl border border-blue-200 bg-blue-50 px-4 py-2.5 text-sm font-medium text-blue-700 transition hover:bg-blue-100" %>

            <%= button_to "Eliminar",
                admin_specialty_path(specialty),
                method: :delete,
                data: { turbo_confirm: "¿Estás seguro de eliminar la especialidad \"#{specialty.name}\"?" },
                class: "inline-flex items-center justify-center rounded-2xl border border-red-200 bg-red-50 px-4 py-2.5 text-sm font-medium text-red-700 transition hover:bg-red-100" %>
          </div>
        </div>
      <% end %>
    </div>

  <% else %>
    <!-- Estado vacío -->
    <div class="overflow-hidden rounded-3xl border border-dashed border-slate-300 bg-white shadow-sm">
      <div class="px-6 py-14 sm:px-10 sm:py-20 text-center">
        <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-slate-100 text-4xl">
          🏥
        </div>

        <div class="mx-auto mt-6 max-w-lg">
          <h2 class="text-2xl font-bold tracking-tight text-slate-900">
            No hay especialidades registradas
          </h2>
          <p class="mt-3 text-sm sm:text-base leading-relaxed text-slate-600">
            Aún no has creado especialidades. Agrega la primera para comenzar a clasificar a los doctores del sistema.
          </p>
        </div>

        <div class="mt-8">
          <%= link_to "Agregar primera especialidad",
              new_admin_specialty_path,
              class: "inline-flex items-center justify-center rounded-2xl bg-violet-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-violet-700" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
