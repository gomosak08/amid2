<div class="min-h-[80vh] bg-gradient-to-b from-violet-50 via-white to-white">
  <div class="w-full py-10 px-4 sm:px-6 lg:px-8 max-w-3xl mx-auto">

    <% if notice.present? %>
      <div class="mb-6 rounded-2xl border border-green-200 bg-green-50 px-4 py-4 text-sm text-green-700 font-medium">
        <%= notice %>
      </div>
    <% end %>

    <div class="mb-6 flex items-center gap-3">
      <%= link_to admin_specialties_path, class: "inline-flex h-10 w-10 items-center justify-center rounded-full bg-white shadow-sm border border-gray-200 text-gray-500 hover:text-violet-600 transition hover:-translate-x-0.5" do %>
        <i class="fa-solid fa-arrow-left"></i>
      <% end %>
      <h1 class="text-2xl font-extrabold text-gray-900 tracking-tight">Detalle de Especialidad</h1>
    </div>

    <div class="overflow-hidden rounded-[24px] border border-gray-200 bg-white shadow-xl shadow-violet-100/30">
      <div class="relative overflow-hidden bg-gradient-to-r from-slate-900 via-violet-800 to-purple-700 px-6 py-8 text-white">
        <div class="absolute inset-0 opacity-10">
          <div class="absolute -right-8 -top-8 h-32 w-32 rounded-full bg-white"></div>
          <div class="absolute -bottom-10 -left-10 h-40 w-40 rounded-full bg-white"></div>
        </div>
        <div class="relative">
          <span class="inline-flex items-center rounded-full bg-white/15 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-violet-100 ring-1 ring-white/20">
            Especialidad médica
          </span>
          <p class="mt-3 text-2xl font-bold"><%= @specialty.name %></p>
        </div>
      </div>

      <div class="p-6 sm:p-8">
        <div class="mb-2 text-sm font-medium text-gray-500">Nombre</div>
        <div class="text-lg font-semibold text-gray-900"><%= @specialty.name %></div>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <%= link_to "Editar especialidad",
              edit_admin_specialty_path(@specialty),
              class: "inline-flex items-center rounded-2xl border border-blue-200 bg-blue-50 px-5 py-2.5 text-sm font-semibold text-blue-700 hover:bg-blue-100 transition" %>

          <%= button_to "Eliminar especialidad",
              admin_specialty_path(@specialty),
              method: :delete,
              data: { turbo_confirm: "¿Estás seguro de eliminar la especialidad \"#{@specialty.name}\"?" },
              class: "inline-flex items-center rounded-2xl border border-red-200 bg-red-50 px-5 py-2.5 text-sm font-semibold text-red-700 hover:bg-red-100 transition" %>
        </div>
      </div>
    </div>
  </div>
</div>
