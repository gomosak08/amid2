<% ts = local_assigns[:time_slot].presence %>

<% if ts.blank? %>
  <div class="mt-4 p-5 bg-blue-50 border border-blue-200 text-blue-800 rounded-xl text-sm font-medium flex items-center gap-3">
    <span class="text-xl">ℹ️</span> Selecciona doctor, fecha y horario para continuar con los datos del paciente.
  </div>
<% else %>
  <div class="border border-gray-200 rounded-xl p-5 sm:p-6 shadow-sm bg-white mb-6">
    <div class="flex items-center gap-2 mb-6">
      <span class="inline-flex items-center justify-center bg-blue-600 text-white rounded-full w-6 h-6 text-xs font-bold">4</span>
      <h2 class="text-base font-bold text-gray-900">Datos del Paciente</h2>
    </div>

    <%= form_with scope: :appointment,
                  url: admin_appointments_path,
                  method: :post,
                  data: { turbo_frame: "_top" },
                  class: "space-y-6" do |f| %>

      <%= f.hidden_field :package_id, value: package.id %>
      <%= f.hidden_field :doctor_id,  value: doctor_id %>
      <%= f.hidden_field :start_date, value: (ts.respond_to?(:iso8601) ? ts.iso8601 : ts) %>
      <%= f.hidden_field :duration, value: duration %>
      <!-- reCAPTCHA como param top-level -->
      <%= hidden_field_tag :recaptcha_token, "", id: "recaptcha_token" %>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        <div>
          <%= f.label :name, "Nombre completo", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= f.text_field :name, required: true, placeholder: "Ej. Juan Pérez",
                class: "block w-full px-4 py-3 text-sm border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 shadow-sm" %>
        </div>

        <div>
          <%= f.label :phone, "Teléfono", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= f.telephone_field :phone, required: true, placeholder: "10 dígitos",
                class: "block w-full px-4 py-3 text-sm border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 shadow-sm" %>
        </div>

        <div>
          <%= f.label :age, "Edad", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= f.number_field :age, min: 0, step: 1, required: true, placeholder: "Años",
                class: "block w-full px-4 py-3 text-sm border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 shadow-sm" %>
        </div>
      </div>

      <div class="pt-4 border-t border-gray-100 flex justify-end">
        <%= f.submit "Reservar cita",
              class: "w-full sm:w-auto px-6 py-3 rounded-xl bg-blue-600 text-white hover:bg-blue-700 text-sm font-semibold shadow-sm transition cursor-pointer" %>
      </div>
    <% end %>
  </div>
<% end %>
