<div class="min-h-[80vh] bg-gradient-to-b from-blue-50 via-white to-white">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Encabezado -->
    <div class="mb-8 overflow-hidden rounded-[28px] border border-gray-200 bg-white shadow-xl shadow-blue-100/40">
      <div class="relative overflow-hidden bg-gradient-to-r from-blue-600 to-cyan-500 px-6 py-8 text-white sm:px-8 sm:py-10">
        <div class="absolute inset-0 opacity-10">
          <div class="absolute -right-8 -top-8 h-32 w-32 rounded-full bg-white"></div>
          <div class="absolute -bottom-10 -left-10 h-40 w-40 rounded-full bg-white"></div>
        </div>

        <div class="relative flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between">
          <div class="max-w-3xl">
            <h1 class="text-2xl font-bold tracking-tight sm:text-3xl lg:text-4xl">
              Administrador de Citas
            </h1>
            <p class="mt-3 text-sm leading-6 text-blue-50 sm:text-base">
              Filtra por fecha, varios doctores y varios estados para localizar rápidamente las citas.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <%= link_to "Restablecer filtros",
                  admin_appointments_path,
                  class: "inline-flex items-center justify-center rounded-2xl border border-white/30 bg-white/10 px-4 py-2.5 text-sm font-semibold text-white backdrop-blur-sm transition hover:bg-white/20" %>
          </div>
        </div>
      </div>

      <!-- Estadísticas -->
      <div class="grid grid-cols-1 gap-4 border-t border-gray-100 bg-white px-6 py-6 md:grid-cols-2 xl:grid-cols-4 sm:px-8">
        <div class="rounded-2xl border border-gray-200 bg-gray-50 p-5">
          <p class="text-sm font-medium text-gray-500">Total de citas</p>
          <p class="mt-2 text-3xl font-bold text-gray-900">
            <%= @appointments.size %>
          </p>
        </div>

        <div class="rounded-2xl border border-blue-100 bg-blue-50 p-5">
          <p class="text-sm font-medium text-blue-700">Programadas</p>
          <p class="mt-2 text-3xl font-bold text-blue-600">
            <%= @appointments.count { |a| a.status == "scheduled" } %>
          </p>
        </div>

        <div class="rounded-2xl border border-emerald-100 bg-emerald-50 p-5">
          <p class="text-sm font-medium text-emerald-700">Completadas</p>
          <p class="mt-2 text-3xl font-bold text-emerald-600">
            <%= @appointments.count { |a| a.status == "completed" } %>
          </p>
        </div>

        <div class="rounded-2xl border border-rose-100 bg-rose-50 p-5">
          <p class="text-sm font-medium text-rose-700">Canceladas</p>
          <p class="mt-2 text-3xl font-bold text-rose-600">
            <%= @appointments.count { |a| ["canceled_by_admin", "canceled_by_client"].include?(a.status) } %>
          </p>
        </div>
      </div>
    </div>

    <!-- Filtros -->
    <div class="mb-8 overflow-hidden rounded-[28px] border border-gray-200 bg-white shadow-xl shadow-blue-100/30">
      <div class="border-b border-gray-100 px-6 py-6 sm:px-8">
        <h2 class="text-xl font-bold text-gray-900">Filtros avanzados</h2>
        <p class="mt-2 text-sm text-gray-600">
          Puedes combinar fecha, varios doctores y varios estados al mismo tiempo.
        </p>
      </div>

      <div class="px-6 py-8 sm:px-8">
        <%= form_with url: admin_appointments_path,
                      method: :get,
                      local: true,
                      class: "space-y-8" do |form| %>

          <!-- Fecha + acciones -->
          <div class="grid grid-cols-1 gap-6 xl:grid-cols-12">
            <div class="xl:col-span-9">
              <label class="mb-3 block text-lg font-semibold text-gray-800">
                Selecciona una fecha
              </label>

              <div
                class="rounded-[24px] border border-gray-200 bg-white p-5 shadow-sm"
                data-controller="date-picker"
                data-date-picker-initial-value="<%= params[:date].presence || Date.current.to_s %>"
              >
                <div class="grid grid-cols-1 gap-6 xl:grid-cols-3">
                  <!-- Panel resumen -->
                  <div class="xl:col-span-1">
                    <div class="rounded-[24px] bg-gradient-to-br from-blue-600 to-cyan-500 p-6 text-white">
                      <p class="mb-2 text-sm uppercase tracking-wide opacity-90">
                        Fecha seleccionada
                      </p>

                      <p class="text-5xl font-bold leading-none" data-date-picker-target="dayNumber">
                        --
                      </p>

                      <p class="mt-3 text-base font-medium capitalize" data-date-picker-target="fullLabel">
                        Selecciona una fecha
                      </p>

                      <p class="mt-5 text-sm opacity-90">
                        Elige el día para filtrar las citas.
                      </p>
                    </div>

                    <div class="mt-4 grid grid-cols-3 gap-2">
                      <button
                        type="button"
                        class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-gray-700 transition hover:bg-gray-50"
                        data-action="click->date-picker#setToday"
                      >
                        Hoy
                      </button>

                      <button
                        type="button"
                        class="rounded-xl border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-gray-700 transition hover:bg-gray-50"
                        data-action="click->date-picker#setTomorrow"
                      >
                        Mañana
                      </button>

                      <button
                        type="button"
                        class="rounded-xl border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-600 transition hover:bg-red-100"
                        data-action="click->date-picker#clearDate"
                      >
                        Limpiar
                      </button>
                    </div>
                  </div>

                  <!-- Calendario -->
                  <div class="xl:col-span-2">
                    <div class="rounded-[24px] border border-gray-200 bg-gray-50 p-4">
                      <p class="mb-3 text-sm font-semibold text-gray-700">
                        Calendario
                      </p>

                      <%= hidden_field_tag :date,
                            params[:date],
                            data: { date_picker_target: "input" } %>

                      <div
                        data-date-picker-target="calendar"
                        class="date-picker-inline"
                      ></div>

                      <p class="mt-4 text-xs text-gray-500">
                        Selecciona un día para filtrar resultados.
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Acciones -->
            <div class="xl:col-span-3 flex items-end">
              <div class="grid w-full grid-cols-1 gap-3">
                <%= form.submit "Aplicar filtros",
                      class: "inline-flex w-full items-center justify-center rounded-2xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700" %>

                <%= link_to "Limpiar",
                      admin_appointments_path,
                      class: "inline-flex w-full items-center justify-center rounded-2xl border border-gray-300 bg-white px-4 py-3 text-sm font-semibold text-gray-700 transition hover:bg-gray-50" %>
              </div>
            </div>
          </div>

          <!-- Doctores y estados -->
          <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
            <!-- Doctores -->
            <div class="rounded-[24px] border border-gray-200 bg-gray-50 p-5">
              <div class="mb-4 flex items-center justify-between">
                <h3 class="text-sm font-bold uppercase tracking-wide text-gray-600">
                  Doctores
                </h3>

                <% if Array(params[:doctor_ids]).reject(&:blank?).any? %>
                  <span class="text-xs font-semibold text-blue-600">
                    <%= Array(params[:doctor_ids]).reject(&:blank?).size %> seleccionado(s)
                  </span>
                <% end %>
              </div>

              <div class="grid max-h-72 grid-cols-1 gap-3 overflow-y-auto pr-1 sm:grid-cols-2">
                <% @doctors.each do |doctor| %>
                  <% checked = Array(params[:doctor_ids]).map(&:to_s).include?(doctor.id.to_s) %>

                  <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-gray-200 bg-white px-4 py-3 transition hover:border-blue-300 hover:bg-blue-50">
                    <%= check_box_tag "doctor_ids[]",
                          doctor.id,
                          checked,
                          class: "mt-1 h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>

                    <div>
                      <p class="text-sm font-semibold text-gray-800">
                        <%= doctor.name %>
                      </p>
                    </div>
                  </label>
                <% end %>
              </div>
            </div>

            <!-- Estados -->
            <div class="rounded-[24px] border border-gray-200 bg-gray-50 p-5">
              <div class="mb-4 flex items-center justify-between">
                <h3 class="text-sm font-bold uppercase tracking-wide text-gray-600">
                  Estados
                </h3>

                <% if Array(params[:statuses]).reject(&:blank?).any? %>
                  <span class="text-xs font-semibold text-indigo-600">
                    <%= Array(params[:statuses]).reject(&:blank?).size %> seleccionado(s)
                  </span>
                <% end %>
              </div>

              <% status_options = [
                ["Programada", "scheduled"],
                ["Completada", "completed"],
                ["Cancelada por admin", "canceled_by_admin"],
                ["Cancelada por cliente", "canceled_by_client"]
              ] %>

              <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                <% status_options.each do |label_text, value| %>
                  <% checked = Array(params[:statuses]).include?(value) %>

                  <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-gray-200 bg-white px-4 py-3 transition hover:border-blue-300 hover:bg-blue-50">
                    <%= check_box_tag "statuses[]",
                          value,
                          checked,
                          class: "mt-1 h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>

                    <div class="flex flex-col gap-1">
                      <span class="text-sm font-semibold text-gray-800">
                        <%= label_text %>
                      </span>

                      <% if value == "scheduled" %>
                        <span class="inline-flex w-fit items-center rounded-full bg-blue-100 px-2.5 py-1 text-xs font-semibold text-blue-700">
                          scheduled
                        </span>
                      <% elsif value == "completed" %>
                        <span class="inline-flex w-fit items-center rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-700">
                          completed
                        </span>
                      <% elsif value == "canceled_by_admin" %>
                        <span class="inline-flex w-fit items-center rounded-full bg-rose-100 px-2.5 py-1 text-xs font-semibold text-rose-700">
                          canceled_by_admin
                        </span>
                      <% elsif value == "canceled_by_client" %>
                        <span class="inline-flex w-fit items-center rounded-full bg-amber-100 px-2.5 py-1 text-xs font-semibold text-amber-700">
                          canceled_by_client
                        </span>
                      <% end %>
                    </div>
                  </label>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Filtros activos -->
      <div class="border-t border-gray-100 bg-gray-50 px-6 py-4 sm:px-8">
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-sm font-semibold text-gray-600">Filtros activos:</span>

          <% if params[:date].present? %>
            <span class="inline-flex items-center rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">
              Fecha: <%= params[:date] %>
            </span>
          <% end %>

          <% Array(params[:doctor_ids]).reject(&:blank?).each do |doctor_id| %>
            <% doctor = @doctors.find { |d| d.id.to_s == doctor_id.to_s } %>
            <% if doctor %>
              <span class="inline-flex items-center rounded-full bg-gray-200 px-3 py-1 text-xs font-semibold text-gray-700">
                Doctor: <%= doctor.name %>
              </span>
            <% end %>
          <% end %>

          <% status_labels = {
            "scheduled" => "Programada",
            "completed" => "Completada",
            "canceled_by_admin" => "Cancelada por admin",
            "canceled_by_client" => "Cancelada por cliente"
          } %>

          <% Array(params[:statuses]).reject(&:blank?).each do |status| %>
            <span class="inline-flex items-center rounded-full bg-indigo-100 px-3 py-1 text-xs font-semibold text-indigo-700">
              Estado: <%= status_labels[status] || status %>
            </span>
          <% end %>

          <% if params[:date].blank? &&
                Array(params[:doctor_ids]).reject(&:blank?).empty? &&
                Array(params[:statuses]).reject(&:blank?).empty? %>
            <span class="text-sm text-gray-400">Ninguno</span>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Tabla -->
    <div class="overflow-hidden rounded-[28px] border border-gray-200 bg-white shadow-xl shadow-blue-100/30">
      <div class="border-b border-gray-100 px-6 py-5 sm:px-8">
        <h2 class="text-lg font-bold text-gray-900">Listado de citas</h2>
        <p class="mt-1 text-sm text-gray-500">
          <%= @appointments.size %> resultado(s)
        </p>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full">
          <thead class="border-b border-gray-200 bg-gray-50">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">ID</th>
              <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">Paciente</th>
              <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">Fecha</th>
              <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">Doctor</th>
              <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">Estado</th>
              <th class="px-6 py-4 text-center text-xs font-bold uppercase tracking-wider text-gray-500">Acciones</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-gray-200 bg-white">
            <% if @appointments.any? %>
              <% @appointments.each do |appointment| %>
                <tr class="transition hover:bg-blue-50/40">
                  <td class="whitespace-nowrap px-6 py-4">
                    <span class="inline-flex items-center rounded-lg bg-gray-100 px-3 py-1 text-sm font-semibold text-gray-700">
                      #<%= appointment.id %>
                    </span>
                  </td>

                  <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-gray-800">
                    <%= appointment.name.presence || "Sin nombre" %>
                  </td>

                  <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-600">
                    <%= I18n.l(
                          appointment.start_date.in_time_zone("America/Mexico_City"),
                          format: :custom,
                          locale: :es
                        ) rescue "N/A" %>
                  </td>

                  <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-600">
                    <%= appointment.doctor&.name || "Sin doctor" %>
                  </td>

                  <td class="whitespace-nowrap px-6 py-4">
                    <% if appointment.status == "scheduled" %>
                      <span class="inline-flex items-center rounded-full bg-blue-100 px-3 py-1 text-xs font-bold text-blue-700">
                        Programada
                      </span>
                    <% elsif appointment.status == "completed" %>
                      <span class="inline-flex items-center rounded-full bg-emerald-100 px-3 py-1 text-xs font-bold text-emerald-700">
                        Completada
                      </span>
                    <% elsif appointment.status == "canceled_by_admin" %>
                      <span class="inline-flex items-center rounded-full bg-rose-100 px-3 py-1 text-xs font-bold text-rose-700">
                        Cancelada por admin
                      </span>
                    <% elsif appointment.status == "canceled_by_client" %>
                      <span class="inline-flex items-center rounded-full bg-amber-100 px-3 py-1 text-xs font-bold text-amber-700">
                        Cancelada por cliente
                      </span>
                    <% else %>
                      <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-xs font-bold text-gray-700">
                        <%= appointment.status %>
                      </span>
                    <% end %>
                  </td>

                  <td class="px-6 py-4">
                    <div class="flex items-center justify-center gap-2">
                      <%= link_to "Editar",
                            edit_admin_appointment_path(appointment),
                            class: "inline-flex items-center rounded-xl bg-blue-50 px-3 py-2 text-sm font-semibold text-blue-700 transition hover:bg-blue-100" %>

                      <% unless appointment.completed? || appointment.canceled_by_admin? || appointment.canceled_by_client? %>
                        <%= link_to "Cancelar",
                              cancel_admin_appointment_path(appointment),
                              data: {
                                turbo_method: :patch,
                                turbo_confirm: "¿Estás seguro de cancelar esta cita?"
                              },
                              class: "inline-flex items-center rounded-xl bg-red-50 px-3 py-2 text-sm font-semibold text-red-700 transition hover:bg-red-100" %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="6" class="px-6 py-14 text-center">
                  <div class="mx-auto max-w-md">
                    <p class="text-base font-semibold text-gray-700">
                      No se encontraron citas
                    </p>
                    <p class="mt-1 text-sm text-gray-500">
                      Ajusta los filtros para probar otra combinación.
                    </p>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>