<div class="border border-gray-200 rounded-xl p-5 sm:p-6 shadow-sm bg-white mb-6">
  <div class="flex items-center gap-2 mb-4">
    <span class="inline-flex items-center justify-center bg-blue-600 text-white rounded-full w-6 h-6 text-xs font-bold">2</span>
    <h2 class="text-base font-bold text-gray-900">Médico y Fecha</h2>
  </div>

  <%= form_with url: available_fields_admin_appointments_path(format: :turbo_stream),
                method: :get,
                class: "space-y-5",
                data: { turbo_stream: true } do |f| %>

    <%= f.hidden_field :package_id, value: package.id %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div class="field">
        <%= f.label :doctor_id, "Doctor", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <%= f.collection_select :doctor_id,
              doctors, :id, :name,
              { prompt: "Selecciona un Doctor", selected: doctor_id },
              { class: "block w-full px-4 py-3 border border-gray-300 bg-white rounded-xl shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
                onchange: "this.form.requestSubmit()" } %>
      </div>

      <div class="field">
        <%= f.label :appointment_date, "Fecha", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <%= f.date_field :appointment_date,
              value: (appointment_date || Date.current),
              class: "block w-full px-4 py-3 border border-gray-300 bg-white rounded-xl shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
              onchange: "this.form.requestSubmit()" %>
      </div>
    </div>
  <% end %>
</div>
