<% collection = local_assigns[:packages] || @packages || [] %>

<%= form_with url: available_fields_admin_appointments_path(format: :turbo_stream),
              method: :get,
              id: "appointment-form",
              class: "space-y-4",
              data: { turbo_stream: true } do |f| %>

  <div class="flex items-center gap-2 mb-4">
    <span class="inline-flex items-center justify-center bg-blue-600 text-white rounded-full w-6 h-6 text-xs font-bold">1</span>
    <h2 class="text-base font-bold text-gray-900">Seleccionar Servicio</h2>
  </div>

  <div class="field">
    <%= f.label :package_id, "Elige un servicio", class: "block text-sm font-semibold text-gray-700 mb-2" %>
    <%= f.collection_select :package_id,
          collection, :id, :name,
          { prompt: "Elige un servicio" },
          { class: "block w-full px-4 py-3 border border-gray-300 bg-white rounded-xl shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
            onchange: "this.form.requestSubmit()" } %>
  </div>
<% end %>
