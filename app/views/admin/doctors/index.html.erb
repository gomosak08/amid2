<!-- app/views/admin/doctors/index.html.erb -->

<div class="w-full max-w-[96vw] mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
  <% total_doctors = @doctors.size %>

  <!-- Header -->
  <div class="relative overflow-hidden rounded-3xl bg-gradient-to-r from-slate-900 via-cyan-800 to-blue-700 px-6 py-8 sm:px-8 sm:py-10 shadow-xl mb-8">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute -top-10 -right-10 h-40 w-40 rounded-full bg-white"></div>
      <div class="absolute bottom-0 left-0 h-28 w-28 rounded-full bg-white"></div>
    </div>

    <div class="relative flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
      <div class="max-w-2xl">
        <span class="inline-flex items-center rounded-full bg-white/15 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-cyan-100 ring-1 ring-white/20">
          Panel administrativo
        </span>

        <h1 class="mt-3 text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-white">
          Administrar Doctores
        </h1>

        <p class="mt-3 text-sm sm:text-base text-cyan-100/90 leading-relaxed">
          Gestiona los doctores, revisa su información y accede rápidamente a sus acciones principales.
        </p>
      </div>

      <div class="w-full sm:w-auto">
        <%= link_to "＋ Agregar Nuevo Doctor",
            new_admin_doctor_path,
            class: "inline-flex w-full sm:w-auto items-center justify-center rounded-2xl bg-white px-5 py-3 text-sm font-semibold text-slate-900 shadow-lg transition hover:scale-[1.01] hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-cyan-800" %>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3 mb-8">
    <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-slate-500">Total de doctores</p>
          <p class="mt-2 text-3xl font-bold tracking-tight text-slate-900"><%= total_doctors %></p>
          <p class="mt-1 text-sm text-slate-500">Registrados en el sistema</p>
        </div>
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-cyan-50 text-cyan-700 text-xl shadow-sm">
          🩺
        </div>
      </div>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-slate-500">Especialidades visibles</p>
          <p class="mt-2 text-3xl font-bold tracking-tight text-slate-900">
            <%= @doctors.map(&:specialty).reject(&:blank?).uniq.count %>
          </p>
          <p class="mt-1 text-sm text-slate-500">Áreas registradas</p>
        </div>
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-700 text-xl shadow-sm">
          📋
        </div>
      </div>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md sm:col-span-2 xl:col-span-1">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-slate-500">Gestión rápida</p>
          <p class="mt-2 text-lg font-bold tracking-tight text-slate-900">
            Edita o elimina registros
          </p>
          <p class="mt-1 text-sm text-slate-500">Desde la tabla o tarjetas</p>
        </div>
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-amber-50 text-amber-700 text-xl shadow-sm">
          ⚙️
        </div>
      </div>
    </div>
  </div>

  <% if @doctors.any? %>
    <!-- Desktop Table -->
    <div class="hidden lg:block overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-200 bg-slate-50/80 px-6 py-4">
        <div class="flex items-center justify-between gap-4">
          <div>
            <h2 class="text-base font-semibold text-slate-900">Listado de doctores</h2>
            <p class="text-sm text-slate-500">Vista general con acciones rápidas</p>
          </div>

          <span class="inline-flex items-center rounded-full bg-cyan-100 px-3 py-1 text-xs font-semibold text-cyan-800">
            <%= total_doctors %> registrados
          </span>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-slate-500">#</th>
              <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-slate-500">Doctor</th>
              <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-slate-500">Especialidad</th>
              <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-slate-500">Correo</th>
              <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-wider text-slate-500">Acciones</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-100 bg-white">
            <% @doctors.each_with_index do |doctor, index| %>
              <tr class="transition hover:bg-slate-50/80">
                <td class="px-6 py-5 align-top">
                  <span class="inline-flex h-8 min-w-[2rem] items-center justify-center rounded-full bg-slate-100 px-2 text-xs font-bold text-slate-700">
                    <%= index + 1 %>
                  </span>
                </td>

                <td class="px-6 py-5 align-top">
                  <div class="max-w-xs">
                    <p class="font-semibold text-slate-900 leading-snug">
                      <%= doctor.name.presence || "Sin nombre" %>
                    </p>
                    <p class="mt-1 text-xs text-slate-500">
                      ID: <%= doctor.id %>
                    </p>
                  </div>
                </td>

                <td class="px-6 py-5 align-top">
                  <span class="inline-flex rounded-full border border-cyan-200 bg-cyan-50 px-3 py-1 text-sm font-semibold text-cyan-700">
                    <%= doctor.specialty.presence || "Sin especialidad" %>
                  </span>
                </td>

                <td class="px-6 py-5 align-top text-sm text-slate-700">
                  <%= doctor.email.presence || "Sin correo" %>
                </td>

                <td class="px-6 py-5 align-top">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to "Editar",
                        edit_admin_doctor_path(doctor),
                        class: "inline-flex items-center rounded-xl border border-blue-200 bg-blue-50 px-3.5 py-2 text-sm font-medium text-blue-700 transition hover:bg-blue-100" %>

                    <%= link_to "Eliminar",
                        admin_doctor_path(doctor),
                        data: {
                          turbo_method: :delete,
                          turbo_confirm: "¿Estás seguro de eliminar a #{doctor.name}?"
                        },
                        class: "inline-flex items-center rounded-xl border border-red-200 bg-red-50 px-3.5 py-2 text-sm font-medium text-red-700 transition hover:bg-red-100" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Mobile / Tablet Cards -->
    <div class="grid grid-cols-1 gap-4 lg:hidden">
      <% @doctors.each_with_index do |doctor, index| %>
        <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition hover:shadow-md">
          <div class="bg-gradient-to-r from-slate-50 to-cyan-50 px-4 py-4 border-b border-slate-200">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="inline-flex h-7 min-w-[1.75rem] items-center justify-center rounded-full bg-slate-900 px-2 text-xs font-bold text-white">
                    <%= index + 1 %>
                  </span>

                  <span class="inline-flex rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600">
                    ID: <%= doctor.id %>
                  </span>
                </div>

                <h2 class="mt-3 text-lg font-bold text-slate-900 break-words">
                  <%= doctor.name.presence || "Sin nombre" %>
                </h2>
              </div>

              <div class="shrink-0">
                <span class="inline-flex rounded-full border border-cyan-200 bg-cyan-50 px-3 py-1 text-xs font-semibold text-cyan-700 whitespace-nowrap">
                  <%= doctor.specialty.presence || "Sin especialidad" %>
                </span>
              </div>
            </div>
          </div>

          <div class="p-4">
            <p class="text-sm leading-relaxed text-slate-600">
              <span class="font-semibold text-slate-800">Correo:</span>
              <%= doctor.email.presence || "Sin correo registrado" %>
            </p>

            <div class="mt-5 grid grid-cols-1 sm:grid-cols-2 gap-2">
              <%= link_to "Editar",
                  edit_admin_doctor_path(doctor),
                  class: "inline-flex items-center justify-center rounded-2xl border border-blue-200 bg-blue-50 px-4 py-2.5 text-sm font-medium text-blue-700 transition hover:bg-blue-100" %>

              <%= link_to "Eliminar",
                  admin_doctor_path(doctor),
                  data: {
                    turbo_method: :delete,
                    turbo_confirm: "¿Estás seguro de eliminar a #{doctor.name}?"
                  },
                  class: "inline-flex items-center justify-center rounded-2xl border border-red-200 bg-red-50 px-4 py-2.5 text-sm font-medium text-red-700 transition hover:bg-red-100" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="overflow-hidden rounded-3xl border border-dashed border-slate-300 bg-white shadow-sm">
      <div class="px-6 py-14 sm:px-10 sm:py-20 text-center">
        <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-slate-100 text-4xl">
          🩺
        </div>

        <div class="mx-auto mt-6 max-w-lg">
          <h2 class="text-2xl font-bold tracking-tight text-slate-900">
            No hay doctores registrados
          </h2>

          <p class="mt-3 text-sm sm:text-base leading-relaxed text-slate-600">
            Aún no has creado doctores. Agrega el primero para comenzar a gestionar horarios, disponibilidad y citas.
          </p>
        </div>

        <div class="mt-8">
          <%= link_to "Agregar primer doctor",
              new_admin_doctor_path,
              class: "inline-flex items-center justify-center rounded-2xl bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700" %>
        </div>
      </div>
    </div>
  <% end %>
</div>