<!-- app/views/admin/doctors/edit.html.erb -->

<div class="mx-auto max-w-[1800px] px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <div class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700 border border-blue-100">
        Administración médica
      </div>

      <h1 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-gray-900">
        Editar doctor
      </h1>

      <p class="mt-2 max-w-2xl text-sm sm:text-base text-gray-600">
        Administra la información de <%= @doctor.name %>, configura disponibilidad, crea bloqueos y revisa sus citas en calendario.
      </p>
    </div>

    <% unless current_user&.doctor? %>
      <div class="flex flex-wrap gap-3">
        <%= link_to admin_doctors_path,
          class: "inline-flex items-center justify-center rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-50 transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="mr-2 h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Regresar a doctores
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- TABS NAV -->
  <div class="mt-8 border-b border-gray-200">
    <nav class="-mb-px flex space-x-8 overflow-x-auto" aria-label="Tabs" id="doctor-tabs-nav">
      <button type="button" onclick="openTab('tab-perfil', this)" class="tab-btn active-tab whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition" aria-current="page">
        Perfil y Horarios
      </button>

      <button type="button" onclick="openTab('tab-calendario', this)" class="tab-btn inactive-tab whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition">
        Calendario
      </button>
    </nav>
  </div>

  <style>
    .active-tab { border-color: #2563eb; color: #1e40af; }
    .inactive-tab { border-color: transparent; color: #6b7280; }
    .inactive-tab:hover { border-color: #d1d5db; color: #374151; }
    .tab-content { display: none; }
    .tab-content.active { display: block; animation: fadeIn 0.3s ease-in-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
  </style>

  <script>
    function openTab(tabId, btn) {
      document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
      document.getElementById(tabId).classList.add('active');

      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('active-tab');
        b.classList.add('inactive-tab');
      });
      btn.classList.remove('inactive-tab');
      btn.classList.add('active-tab');
      
      if(tabId === 'tab-calendario') {
        window.dispatchEvent(new Event('resize'));
      }
    }
  </script>

  <!-- TAB 1: PERFIL -->
  <div id="tab-perfil" class="tab-content active mt-8">
  <!-- Formulario del doctor -->
  <section class="mt-8 rounded-3xl border border-gray-200 bg-white shadow-sm overflow-hidden">
    <div class="border-b border-gray-100 bg-gray-50/70 px-6 py-4">
      <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-xl font-semibold text-gray-900">Información del doctor</h2>
          <p class="text-sm text-gray-600">Actualiza sus datos generales y configuración base.</p>
        </div>
      </div>
    </div>

    <div class="p-6">
      <%= render "form" %>
    </div>
  </section>

  </div>

  <!-- TAB 2: CALENDARIO -->
  <div id="tab-calendario" class="tab-content mt-8">
    <section class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
      <div class="border-b border-gray-100 bg-slate-50 px-5 py-5 sm:px-6">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
          <div>
            <h3 class="text-2xl font-semibold text-gray-900">Agenda y Excepciones</h3>
            <p class="mt-1 text-sm text-gray-600">
              Haz clic o arrastra sobre el calendario para bloquear fechas/horas, o haz clic en una cita para ver detalles.
            </p>
          </div>

          <div class="flex flex-wrap gap-2 text-xs font-medium">
            <span class="inline-flex items-center gap-2 rounded-full border border-blue-100 bg-blue-50 px-3 py-1 text-blue-700">
              <span class="h-2.5 w-2.5 rounded-full bg-blue-500"></span>
              Citas
            </span>
            <span class="inline-flex items-center gap-2 rounded-full border border-red-100 bg-red-50 px-3 py-1 text-red-700">
              <span class="h-2.5 w-2.5 rounded-full bg-red-500"></span>
              Día bloqueado
            </span>
            <span class="inline-flex items-center gap-2 rounded-full border border-orange-100 bg-orange-50 px-3 py-1 text-orange-700">
              <span class="h-2.5 w-2.5 rounded-full bg-orange-500"></span>
              Horario bloqueado
            </span>
          </div>
        </div>
      </div>

      <div class="grid gap-0 xl:grid-cols-[minmax(0,1fr)_360px]"
           data-controller="doctor-calendar"
           data-doctor-calendar-events-url-value="<%= calendar_events_admin_doctor_path(@doctor) %>">

        <div class="min-w-0 border-b border-gray-200 p-3 sm:p-5 xl:border-b-0 xl:border-r relative">
          <div class="doctor-calendar-shell">
            <div data-doctor-calendar-target="calendar" class="doctor-calendar min-h-[680px]"></div>
          </div>
          
          <!-- Modal Flotante de Creación de Bloqueo -->
          <div data-doctor-calendar-target="blockModal"
               class="absolute z-[40] hidden w-[320px] rounded-2xl border border-gray-200 bg-white shadow-2xl transition-all"
               style="top: 50%; left: 50%; transform: translate(-50%, -50%);">
            <div class="px-4 py-3 border-b border-gray-100 bg-slate-50 rounded-t-2xl flex justify-between items-center">
              <h4 class="font-semibold text-gray-900 text-sm">Añadir Bloqueo</h4>
              <button type="button" data-action="click->doctor-calendar#hideBlockModal" class="text-gray-400 hover:text-gray-600">&times;</button>
            </div>
            <div class="p-4">
              <%= form_with url: create_unified_block_admin_doctor_path(@doctor), method: :post, local: true, class: "space-y-3" do |form| %>
                <div class="grid grid-cols-2 gap-3 mb-2">
                  <div>
                    <label class="text-xs font-medium text-gray-500 mb-1 block">Fecha de inicio</label>
                    <input type="date" name="start_date" data-doctor-calendar-target="blockStartDate" class="w-full text-sm rounded-lg border-gray-300 px-2 py-1.5 shadow-sm focus:border-red-400 focus:ring-1 focus:ring-red-200" required>
                  </div>
                  <div>
                    <label class="text-xs font-medium text-gray-500 mb-1 block">Fecha de fin</label>
                    <input type="date" name="end_date" data-doctor-calendar-target="blockEndDate" class="w-full text-sm rounded-lg border-gray-300 px-2 py-1.5 shadow-sm focus:border-red-400 focus:ring-1 focus:ring-red-200" required>
                  </div>
                  <div>
                    <label class="text-xs font-medium text-gray-500 mb-1 block">Hora inicio</label>
                    <input type="time" name="start_time" data-doctor-calendar-target="blockStartTime" class="w-full text-sm rounded-lg border-gray-300 px-2 py-1.5 shadow-sm focus:border-red-400 focus:ring-1 focus:ring-red-200">
                  </div>
                  <div>
                    <label class="text-xs font-medium text-gray-500 mb-1 block">Hora fin</label>
                    <input type="time" name="end_time" data-doctor-calendar-target="blockEndTime" class="w-full text-sm rounded-lg border-gray-300 px-2 py-1.5 shadow-sm focus:border-red-400 focus:ring-1 focus:ring-red-200">
                  </div>
                </div>

                <div class="hidden">
                  <span data-doctor-calendar-target="blockDisplay"></span>
                </div>
                
                <label class="flex items-start gap-2 pt-2 cursor-pointer">
                  <%= form.check_box :is_recurring, class: "mt-0.5 h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
                  <span class="text-sm text-gray-700">Crear bloqueo semanal recurrente (sobre aplicar a los días seleccionados)</span>
                </label>
                
                <div>
                  <%= form.text_field :reason, placeholder: "Motivo (opcional)", class: "w-full text-sm rounded-lg border-gray-300 px-3 py-2 shadow-sm focus:border-red-400 focus:ring-1 focus:ring-red-200" %>
                </div>

                <div class="pt-2">
                  <button type="submit" class="w-full justify-center inline-flex items-center rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-red-700 transition">
                    Crear bloqueo
                  </button>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <aside class="bg-slate-50/70 p-5 hidden xl:flex xl:flex-col overflow-y-auto max-h-[850px]">
          
          <div class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm mb-6 shrink-0">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-semibold uppercase text-gray-500">Día seleccionado</p>
                <h4 data-doctor-calendar-target="selectedDate" class="mt-1 text-lg font-semibold text-gray-900"></h4>
              </div>
              <span data-doctor-calendar-target="dayCount" class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-600"></span>
            </div>

            <div data-doctor-calendar-target="daySummary" class="mt-4 space-y-3"></div>

            <div data-doctor-calendar-target="dayEmpty" class="mt-4 rounded-xl border border-dashed border-gray-300 bg-gray-50 px-4 py-6 text-center">
              <p class="text-sm font-medium text-gray-700">Sin eventos en este día</p>
            </div>
          </div>

          <div class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm shrink-0">
            <p class="text-xs font-semibold uppercase text-gray-500 mb-3">Mis Bloqueos Activos</p>
            
            <% if @unavailabilities.present? || @time_blocks.present? %>
              <div class="space-y-4">
                <% if @unavailabilities.present? %>
                  <div class="text-[10px] font-bold uppercase text-red-600 tracking-wider">Fechas Específicas</div>
                  <div class="space-y-2">
                    <% @unavailabilities.each do |u| %>
                      <div class="flex items-center justify-between gap-2 border-b border-gray-100 pb-2 last:border-0 last:pb-0">
                        <div class="min-w-0 flex-1">
                          <p class="text-xs font-semibold text-gray-800"><%= I18n.l(u.date, format: :short) %></p>
                          <p class="text-[10px] text-gray-500 truncate"><%= u.start_time.present? ? "#{u.start_time.strftime('%H:%M')} - #{u.end_time.strftime('%H:%M')}" : "Todo el día" %> <%= "- #{u.reason}" if u.reason.present? %></p>
                        </div>
                        <%= button_to destroy_unavailability_admin_doctor_path(@doctor), method: :delete, params: { unavailability_id: u.id }, title: "Eliminar", class: "text-gray-400 hover:text-red-600 p-1" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>

                <% if @time_blocks.present? %>
                  <div class="text-[10px] font-bold uppercase text-orange-600 tracking-wider pt-2">Recurrentes</div>
                  <div class="space-y-2">
                    <% day_names = %w[D L M X J V S] %>
                    <% @time_blocks.each do |b| %>
                      <div class="flex items-center justify-between gap-2 border-b border-gray-100 pb-2 last:border-0 last:pb-0">
                        <div class="min-w-0 flex-1">
                          <p class="text-xs font-semibold text-gray-800"><%= Array(b.days_of_week).map { |d| day_names[d.to_i] }.join(",") %> | <%= b.starts_at.strftime("%H:%M") %>-<%= b.ends_at.strftime("%H:%M") %></p>
                          <p class="text-[10px] text-gray-500 truncate"><%= b.reason.presence || "Sin motivo" %></p>
                        </div>
                        <%= button_to destroy_time_block_admin_doctor_path(@doctor), method: :delete, params: { time_block_id: b.id }, title: "Eliminar", class: "text-gray-400 hover:text-red-600 p-1" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-xs text-gray-400 italic">No hay bloqueos activos.</p>
            <% end %>
          </div>

        </aside>

        <!-- Popover -->
        <div data-doctor-calendar-target="popover"
             class="fixed z-[9999] hidden max-w-sm rounded-2xl border border-gray-200 bg-white shadow-2xl">
          <div class="p-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div data-doctor-calendar-target="popoverTitle" class="text-sm font-semibold text-gray-900"></div>
                <div data-doctor-calendar-target="popoverMeta" class="mt-1 text-xs text-gray-600"></div>
              </div>

              <button type="button"
                      data-action="click->doctor-calendar#hidePopover"
                      class="rounded-lg p-1 text-gray-400 transition hover:bg-gray-100 hover:text-gray-700"
                      aria-label="Cerrar detalles">
                x
              </button>
            </div>

            <div data-doctor-calendar-target="popoverBody" class="mt-3 text-sm text-gray-700"></div>
            <div data-doctor-calendar-target="popoverFooter" class="mt-3 text-xs text-gray-500"></div>
          </div>
        </div>
      </div>
    </section>
  </div>
</div><!-- /mx-auto max-w container -->

<script>
  document.addEventListener("turbo:load", function () {
    document.querySelectorAll('.tab-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        setTimeout(function() { window.dispatchEvent(new Event('resize')) }, 80)
      })
    })
  })
</script>
