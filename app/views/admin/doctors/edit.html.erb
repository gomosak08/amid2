<!-- app/views/admin/doctors/edit.html.erb -->

<div class="mx-auto max-w-[1800px] px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <div class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700 border border-blue-100">
        Administración médica
      </div>

      <h1 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-gray-900">
        Editar doctor
      </h1>

      <p class="mt-2 max-w-2xl text-sm sm:text-base text-gray-600">
        Administra la información de <%= @doctor.name %>, configura disponibilidad, crea bloqueos y revisa sus citas en calendario.
      </p>
    </div>

    <% unless current_user&.doctor? %>
      <div class="flex flex-wrap gap-3">
        <%= link_to admin_doctors_path,
          class: "inline-flex items-center justify-center rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-50 transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="mr-2 h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Regresar a doctores
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- TABS NAV -->
  <div class="mt-8 border-b border-gray-200">
    <nav class="-mb-px flex space-x-8 overflow-x-auto" aria-label="Tabs" id="doctor-tabs-nav">
      <button type="button" onclick="openTab('tab-perfil', this)" class="tab-btn active-tab whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition" aria-current="page">
        Perfil y Horarios
      </button>

      <button type="button" onclick="openTab('tab-calendario', this)" class="tab-btn inactive-tab whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition">
        Calendario
      </button>

      <button type="button" onclick="openTab('tab-bloqueos', this)" class="tab-btn inactive-tab whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition">
        Excepciones y Bloqueos
      </button>
    </nav>
  </div>

  <style>
    .active-tab { border-color: #2563eb; color: #1e40af; }
    .inactive-tab { border-color: transparent; color: #6b7280; }
    .inactive-tab:hover { border-color: #d1d5db; color: #374151; }
    .tab-content { display: none; }
    .tab-content.active { display: block; animation: fadeIn 0.3s ease-in-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
  </style>

  <script>
    function openTab(tabId, btn) {
      document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
      document.getElementById(tabId).classList.add('active');

      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('active-tab');
        b.classList.add('inactive-tab');
      });
      btn.classList.remove('inactive-tab');
      btn.classList.add('active-tab');
      
      if(tabId === 'tab-calendario') {
        window.dispatchEvent(new Event('resize'));
      }
    }
  </script>

  <!-- TAB 1: PERFIL -->
  <div id="tab-perfil" class="tab-content active mt-8">
  <!-- Formulario del doctor -->
  <section class="mt-8 rounded-3xl border border-gray-200 bg-white shadow-sm overflow-hidden">
    <div class="border-b border-gray-100 bg-gray-50/70 px-6 py-4">
      <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-xl font-semibold text-gray-900">Información del doctor</h2>
          <p class="text-sm text-gray-600">Actualiza sus datos generales y configuración base.</p>
        </div>
      </div>
    </div>

    <div class="p-6">
      <%= render "form" %>
    </div>
  </section>

  </div>

  <!-- TAB 2: CALENDARIO -->
  <div id="tab-calendario" class="tab-content mt-4">
  <!-- Calendario -->
  <section class="mt-10 rounded-3xl border border-gray-200 bg-white shadow-sm overflow-hidden">
    <div class="border-b border-gray-100 bg-gray-50/70 px-6 py-5">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h3 class="text-2xl font-semibold text-gray-900">Calendario de citas</h3>
          <p class="mt-1 text-sm text-gray-600">
            Pasa el cursor sobre un evento para ver más detalles.
          </p>
        </div>

        <span class="inline-flex rounded-full border border-gray-200 bg-white px-3 py-1 text-xs font-medium text-gray-500">
          Vista general de agenda
        </span>
      </div>
    </div>

    <div class="p-6"
         data-controller="doctor-calendar"
         data-doctor-calendar-events-url-value="<%= calendar_events_admin_doctor_path(@doctor) %>">

      <div class="overflow-hidden rounded-3xl border border-gray-200 bg-white">
        <div class="flex flex-col gap-2 border-b border-gray-200 bg-gradient-to-r from-gray-50 to-white px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <div class="text-sm font-semibold text-gray-800">Vista calendario</div>
            <div class="text-xs text-gray-500">Consulta citas, horarios ocupados y detalles del evento.</div>
          </div>

          <div class="text-xs text-gray-500">
            Tip: coloca el cursor sobre una cita
          </div>
        </div>

        <div class="p-4 sm:p-5">
          <div data-doctor-calendar-target="calendar" class="min-h-[850px] rounded-2xl bg-white"></div>
        </div>
      </div>

      <!-- Popover -->
      <div data-doctor-calendar-target="popover"
           class="fixed z-[9999] hidden max-w-sm rounded-2xl border border-gray-200 bg-white shadow-2xl">
        <div class="p-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div data-doctor-calendar-target="popoverTitle" class="text-sm font-semibold text-gray-900"></div>
              <div data-doctor-calendar-target="popoverMeta" class="mt-1 text-xs text-gray-600"></div>
            </div>

            <button type="button"
                    data-action="click->doctor-calendar#hidePopover"
                    class="rounded-lg p-1 text-gray-400 hover:bg-gray-100 hover:text-gray-700 transition">
              ✕
            </button>
          </div>

          <div data-doctor-calendar-target="popoverBody" class="mt-3 text-sm text-gray-700"></div>
          <div data-doctor-calendar-target="popoverFooter" class="mt-3 text-xs text-gray-500"></div>
        </div>
      </div>
    </div>
  </section>
</div>
  </div>

  <!-- TAB 3: BLOQUEOS -->
  <div id="tab-bloqueos" class="tab-content mt-8">

  <!-- Resumen -->
  <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="rounded-2xl border border-blue-100 bg-gradient-to-br from-blue-50 to-white p-5 shadow-sm">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-blue-700">Doctor</p>
          <p class="mt-1 text-lg font-semibold text-gray-900"><%= @doctor.name %></p>
        </div>
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white text-blue-600 shadow-sm border border-blue-100">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A9 9 0 1118.88 17.804M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
      </div>
    </div>

    <div class="rounded-2xl border border-red-100 bg-gradient-to-br from-red-50 to-white p-5 shadow-sm">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-red-700">Bloqueos por día</p>
          <p class="mt-1 text-2xl font-bold text-gray-900"><%= @unavailabilities.size %></p>
        </div>
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white text-red-600 shadow-sm border border-red-100">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-12.728 12.728M5.636 5.636l12.728 12.728"/>
          </svg>
        </div>
      </div>
    </div>

    <div class="rounded-2xl border border-orange-100 bg-gradient-to-br from-orange-50 to-white p-5 shadow-sm">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-orange-700">Bloqueos recurrentes</p>
          <p class="mt-1 text-2xl font-bold text-gray-900"><%= @time_blocks.size %></p>
        </div>
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white text-orange-600 shadow-sm border border-orange-100">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3M12 22a10 10 0 100-20 10 10 0 000 20z"/>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════ BLOQUEO POR DÍA ═══════════ -->
  <div class="mt-10 grid grid-cols-1 xl:grid-cols-12 gap-8 items-start">

    <section class="xl:col-span-7 rounded-3xl border border-gray-200 bg-white shadow-sm overflow-hidden"
             data-controller="block-picker">

      <div class="border-b border-gray-100 px-6 py-5 bg-gradient-to-r from-red-50 to-white">
        <div class="inline-flex rounded-full border border-red-200 bg-white px-3 py-1 text-xs font-semibold text-red-700">Día completo</div>
        <h3 class="mt-3 text-xl font-semibold text-gray-900">Bloquear días</h3>
        <p class="mt-1 text-sm text-gray-600">Haz clic en un día o arrastra para seleccionar un rango. Úsalo para vacaciones, congresos o días no laborables.</p>
      </div>

      <div class="p-6">
        <div class="overflow-hidden rounded-2xl border border-gray-100 bg-gray-50 p-3">
          <div data-block-picker-target="dayCalendar" class="min-h-[340px]"></div>
        </div>

        <div class="mt-4 flex items-center gap-3 rounded-2xl border border-dashed border-red-200 bg-red-50/50 px-4 py-3">
          <span class="text-lg">📅</span>
          <span data-block-picker-target="dayDisplay" class="text-sm font-medium text-red-700">Ningún día seleccionado</span>
        </div>

        <%= form_with url: mark_unavailable_range_admin_doctor_path(@doctor), method: :post, local: true, class: "mt-5 space-y-4" do |form| %>
          <input type="hidden" name="start_date" data-block-picker-target="startDate">
          <input type="hidden" name="end_date"   data-block-picker-target="endDate">

          <div>
            <%= form.label :reason, "Motivo (opcional)", class: "mb-2 block text-sm font-medium text-gray-700" %>
            <%= form.text_field :reason, placeholder: "Vacaciones / Congreso / Permiso / etc.",
                  class: "block w-full rounded-xl border border-gray-300 px-4 py-3 shadow-sm focus:border-red-400 focus:ring-2 focus:ring-red-200" %>
          </div>

          <div class="flex items-center gap-3">
            <button type="submit"
                    data-block-picker-target="daySubmit"
                    disabled
                    class="inline-flex items-center justify-center rounded-xl bg-red-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-red-700 transition disabled:opacity-40 disabled:cursor-not-allowed">
              Bloquear días seleccionados
            </button>
            <button type="button"
                    data-action="click->block-picker#clearDaySelection"
                    class="text-sm text-gray-500 hover:text-gray-700 transition">
              Limpiar selección
            </button>
          </div>
        <% end %>
      </div>
    </section>

    <aside class="xl:col-span-5 rounded-3xl border border-gray-200 bg-white shadow-sm overflow-hidden">
      <div class="border-b border-gray-100 px-6 py-5 bg-red-50/50">
        <h4 class="text-lg font-semibold text-gray-900">Bloqueos por día activos</h4>
        <p class="mt-1 text-sm text-gray-600">Haz clic en "Eliminar" para quitar uno.</p>
      </div>
      <div class="p-6">
        <% if @unavailabilities.present? %>
          <div class="max-h-[480px] overflow-y-auto pr-1 space-y-3">
            <% @unavailabilities.each do |u| %>
              <div class="flex items-start justify-between gap-4 rounded-2xl border border-gray-200 bg-white p-4">
                <div class="min-w-0">
                  <div class="text-sm font-semibold text-gray-900"><%= I18n.l(u.date) %></div>
                  <% if u.reason.present? %>
                    <p class="mt-1 text-sm text-gray-600 break-words"><%= u.reason %></p>
                  <% else %>
                    <p class="mt-1 text-xs text-gray-400">Sin motivo registrado</p>
                  <% end %>
                </div>
                <%= button_to "Eliminar",
                      destroy_unavailability_admin_doctor_path(@doctor),
                      method: :delete,
                      params: { unavailability_id: u.id },
                      data: { turbo_confirm: "¿Eliminar el bloqueo del #{I18n.l(u.date)}?" },
                      class: "shrink-0 inline-flex items-center rounded-xl border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-100 transition" %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-2xl border border-dashed border-gray-300 bg-gray-50 px-6 py-10 text-center">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-2xl bg-white border border-gray-200 text-gray-400 text-xl">📅</div>
            <p class="mt-4 text-sm font-medium text-gray-700">No hay bloqueos por día</p>
            <p class="mt-1 text-xs text-gray-500">Selecciona días en el calendario para crear uno.</p>
          </div>
        <% end %>
      </div>
    </aside>
  </div>

  <!-- ═══════════ BLOQUEO RECURRENTE ═══════════ -->
  <div class="mt-10 grid grid-cols-1 xl:grid-cols-12 gap-8 items-start">

    <section class="xl:col-span-7 rounded-3xl border border-gray-200 bg-white shadow-sm overflow-hidden"
             data-controller="block-picker">

      <div class="border-b border-gray-100 px-6 py-5 bg-gradient-to-r from-orange-50 to-white">
        <div class="inline-flex rounded-full border border-orange-200 bg-white px-3 py-1 text-xs font-semibold text-orange-700">Horario recurrente</div>
        <h3 class="mt-3 text-xl font-semibold text-gray-900">Bloquear horas semanales</h3>
        <p class="mt-1 text-sm text-gray-600">Arrastra un bloque de tiempo sobre el día de la semana que deseas bloquear. Puedes agregar varios días arrastrando uno por uno.</p>
      </div>

      <div class="p-6">
        <div class="mb-4 flex items-start gap-3 rounded-2xl border border-orange-100 bg-orange-50/60 px-4 py-3 text-sm text-orange-800">
          <span class="mt-0.5">💡</span>
          <span>Arrastra sobre una columna de día para seleccionar el horario bloqueado. Arrastra en otros días para acumular selecciones con el mismo horario.</span>
        </div>

        <div class="overflow-hidden rounded-2xl border border-gray-100 bg-gray-50 p-3">
          <div data-block-picker-target="weekCalendar" class="min-h-[520px]"></div>
        </div>

        <div class="mt-4 flex items-center gap-3 rounded-2xl border border-dashed border-orange-200 bg-orange-50/50 px-4 py-3">
          <span class="text-lg">🕐</span>
          <span data-block-picker-target="timeDisplay" class="text-sm font-medium text-orange-700">Ningún horario seleccionado</span>
        </div>

        <%= form_with url: create_time_block_admin_doctor_path(@doctor), method: :post, local: true, class: "mt-5 space-y-4" do |form| %>
          <input type="hidden" name="starts_at"    data-block-picker-target="startsAt">
          <input type="hidden" name="ends_at"      data-block-picker-target="endsAt">
          <input type="hidden" name="days_of_week_json" data-block-picker-target="daysOfWeek" value="[]">

          <div>
            <%= form.label :reason, "Etiqueta o motivo (opcional)", class: "mb-2 block text-sm font-medium text-gray-700" %>
            <%= form.text_field :reason, placeholder: "Comida / Junta / Clase / Procedimiento / etc.",
                  class: "block w-full rounded-xl border border-gray-300 px-4 py-3 shadow-sm focus:border-orange-400 focus:ring-2 focus:ring-orange-200" %>
          </div>

          <div class="flex items-center gap-3 flex-wrap">
            <button type="submit"
                    data-block-picker-target="timeSubmit"
                    disabled
                    class="inline-flex items-center justify-center rounded-xl bg-orange-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-orange-700 transition disabled:opacity-40 disabled:cursor-not-allowed">
              Crear bloqueo recurrente
            </button>
            <button type="button"
                    data-action="click->block-picker#clearWeekSelection"
                    class="text-sm text-gray-500 hover:text-gray-700 transition">
              Limpiar selección
            </button>
          </div>
        <% end %>
      </div>
    </section>

    <aside class="xl:col-span-5 rounded-3xl border border-gray-200 bg-white shadow-sm overflow-hidden">
      <div class="border-b border-gray-100 px-6 py-5 bg-orange-50/50">
        <h4 class="text-lg font-semibold text-gray-900">Bloqueos recurrentes activos</h4>
        <p class="mt-1 text-sm text-gray-600">Haz clic en "Eliminar" para quitar uno.</p>
      </div>
      <div class="p-6">
        <% if @time_blocks.present? %>
          <div class="max-h-[520px] overflow-y-auto pr-1 space-y-3">
            <% day_names = %w[Dom Lun Mar Mié Jue Vie Sáb] %>
            <% @time_blocks.each do |b| %>
              <div class="flex items-start justify-between gap-4 rounded-2xl border border-gray-200 bg-white p-4">
                <div class="min-w-0">
                  <div class="text-sm font-semibold text-gray-900">
                    <%= b.starts_at.strftime("%H:%M") %> – <%= b.ends_at.strftime("%H:%M") %>
                  </div>
                  <p class="mt-1 text-xs text-gray-600">
                    Días: <%= Array(b.days_of_week).map { |d| day_names[d.to_i] }.join(", ") %>
                  </p>
                  <% if b.reason.present? %>
                    <p class="mt-1 text-sm text-gray-600 break-words"><%= b.reason %></p>
                  <% else %>
                    <p class="mt-1 text-xs text-gray-400">Sin etiqueta</p>
                  <% end %>
                </div>
                <%= button_to "Eliminar",
                      destroy_time_block_admin_doctor_path(@doctor),
                      method: :delete,
                      params: { time_block_id: b.id },
                      data: { turbo_confirm: "¿Eliminar este bloqueo recurrente?" },
                      class: "shrink-0 inline-flex items-center rounded-xl border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-100 transition" %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-2xl border border-dashed border-gray-300 bg-gray-50 px-6 py-10 text-center">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-2xl bg-white border border-gray-200 text-gray-400 text-xl">🕐</div>
            <p class="mt-4 text-sm font-medium text-gray-700">No hay bloqueos recurrentes</p>
            <p class="mt-1 text-xs text-gray-500">Arrastra en el calendario semanal para crear uno.</p>
          </div>
        <% end %>
      </div>
    </aside>
  </div>

  </div><!-- /tab-bloqueos -->
</div><!-- /mx-auto max-w container -->

<script>
  document.addEventListener("turbo:load", function () {
    document.querySelectorAll('.tab-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        setTimeout(function() { window.dispatchEvent(new Event('resize')) }, 80)
      })
    })
  })
</script>
