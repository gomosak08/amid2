<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="mb-8 overflow-hidden rounded-[28px] border border-slate-200 bg-white shadow-xl shadow-blue-100/40">
    <div class="bg-gradient-to-r from-blue-600 to-cyan-500 px-6 py-8 text-white sm:px-8 sm:py-10">
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <span class="inline-flex items-center rounded-full bg-white/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-white/90">
            Agenda en línea
          </span>
          <h1 class="mt-3 text-3xl font-bold sm:text-4xl">
            Elige el paquete para tu cita
          </h1>
          <p class="mt-2 max-w-2xl text-sm text-blue-50 sm:text-base">
            Selecciona uno de los paquetes disponibles para continuar con el agendado.
          </p>
        </div>

        <div class="rounded-2xl bg-white/10 px-4 py-3 text-sm text-white/95 backdrop-blur">
          <div class="font-semibold">Paso 1 de 2</div>
          <div class="text-white/80">Primero elige tu paquete</div>
        </div>
      </div>
    </div>

    <div class="border-t border-slate-100 bg-slate-50 px-6 py-4 sm:px-8">
      <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1.5 text-sm text-slate-600 shadow-sm ring-1 ring-slate-200">
        <i class="fa-solid fa-box-open text-blue-600"></i>
        <span><%= @packages.size %> paquetes disponibles</span>
      </span>
    </div>
  </div>

  <% grouped_packages = @packages.group_by(&:kind) %>

  <div class="space-y-10">
    <% grouped_packages.each do |kind, items| %>
      <section>
        <div class="mb-4 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-blue-50 text-blue-600">
            <% icon =
              case kind
              when "servicio" then "fa-stethoscope"
              when "paquete" then "fa-box"
              when "cirugia" then "fa-user-doctor"
              else "fa-briefcase-medical"
              end
            %>
            <i class="fa-solid <%= icon %>"></i>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-slate-800">
              <%= kind.present? ? kind.to_s.humanize.pluralize : "Disponibles" %>
            </h2>
            <p class="text-sm text-slate-500">
              Elige una opción para continuar con tu cita.
            </p>
          </div>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
          <% items.each do |package| %>
            <div class="group overflow-hidden rounded-[24px] border border-slate-200 bg-white shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-xl">
              <% if package.image.present? %>
                <div class="h-52 overflow-hidden bg-slate-100">
                  <%= image_tag package.image, class: "h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]" %>
                </div>
              <% else %>
                <div class="flex h-52 items-center justify-center bg-gradient-to-br from-blue-50 to-cyan-50 text-blue-500">
                  <i class="fa-solid fa-notes-medical text-4xl"></i>
                </div>
              <% end %>

              <div class="p-5">
                <span class="inline-flex rounded-full bg-blue-50 px-2.5 py-1 text-xs font-semibold text-blue-700 ring-1 ring-blue-100">
                  <%= kind.present? ? kind.to_s.humanize : "Paquete" %>
                </span>

                <h3 class="mt-3 text-lg font-bold leading-snug text-slate-800">
                  <%= package.name %>
                </h3>

                <% if package.respond_to?(:price) && package.price.present? %>
                  <div class="mt-3 text-lg font-extrabold text-slate-900">
                    <%= number_to_currency(package.price) %>
                  </div>
                <% end %>

                <% if package.respond_to?(:description) && package.description.present? %>
                  <p class="mt-3 mb-5 text-sm leading-6 text-slate-500">
                    <%= truncate(strip_tags(package.description), length: 140) %>
                  </p>
                <% else %>
                  <p class="mt-3 mb-5 text-sm leading-6 text-slate-400">
                    Continúa para ver la disponibilidad y completar tu cita.
                  </p>
                <% end %>

                <div class="flex gap-3">
                  <%= link_to "Ver detalle",
                        package_path(package),
                        class: "inline-flex flex-1 items-center justify-center rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-700 no-underline transition hover:bg-slate-50" %>

                  <%= link_to new_appointment_path(package_id: package.id),
                        class: "inline-flex flex-1 items-center justify-center gap-2 rounded-xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white no-underline transition hover:bg-blue-700" do %>
                    <i class="fa-solid fa-calendar-check"></i>
                    Elegir
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</div>