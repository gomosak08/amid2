<!-- app/views/appointments/edit.html.erb -->
<div class="min-h-[80vh] bg-gradient-to-b from-blue-50 via-white to-white">
  <div class="mx-auto max-w-2xl px-4 py-8 sm:px-6 lg:max-w-4xl lg:px-8">
    <% status_key   = (@appointment.status.presence || "scheduled").to_s %>
    <% status_label = @appointment.status_label %>

    <% status_class =
        case status_key
        when "scheduled"
          "bg-green-100 text-green-800 ring-1 ring-inset ring-green-200"
        when "canceled_by_admin", "canceled_by_client"
          "bg-red-100 text-red-800 ring-1 ring-inset ring-red-200"
        else
          "bg-gray-100 text-gray-800 ring-1 ring-inset ring-gray-200"
        end %>

    <div class="overflow-hidden rounded-[28px] border border-gray-200 bg-white shadow-xl shadow-gray-200/70">
      <!-- Header -->
      <div class="relative overflow-hidden bg-gradient-to-r from-blue-600 via-indigo-500 to-sky-500 px-6 py-10 text-white sm:px-8">
        <div class="absolute inset-0 opacity-10">
          <div class="absolute -top-10 -right-10 h-36 w-36 rounded-full bg-white"></div>
          <div class="absolute -bottom-12 -left-10 h-44 w-44 rounded-full bg-white"></div>
        </div>

        <div class="relative text-center">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-white/15 backdrop-blur-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>

          <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">
            Detalles de tu cita
          </h1>
          <p class="mt-3 text-sm leading-6 text-blue-50 sm:text-base">
            Administra tu cita, consulta la información y descarga tus resultados médicos aquí.
          </p>
        </div>
      </div>

      <!-- Content -->
      <div class="px-6 py-8 sm:px-8">
        <!-- Estado -->
        <div class="mb-6 flex flex-col gap-3 rounded-2xl bg-gray-50 p-4 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">
              Estado actual
            </p>
            <div class="mt-2">
              <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold sm:text-sm <%= status_class %>">
                <%= status_label %>
              </span>
            </div>
          </div>

          <div class="text-sm text-gray-500">
            Código: <span class="font-mono font-semibold text-gray-800"><%= @appointment.unique_code %></span>
          </div>
        </div>

        <!-- Resumen -->
        <div class="mb-8">
          <h2 class="mb-4 text-lg font-bold text-gray-900 sm:text-xl">
            Resumen de la cita
          </h2>

          <dl class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div class="rounded-2xl border border-gray-100 bg-gray-50 p-4">
              <dt class="text-sm font-medium text-gray-500">Paciente</dt>
              <dd class="mt-1 text-base font-semibold text-gray-900"><%= @appointment.name %></dd>
            </div>

            <div class="rounded-2xl border border-gray-100 bg-gray-50 p-4">
              <dt class="text-sm font-medium text-gray-500">Médico</dt>
              <dd class="mt-1 text-base font-semibold text-gray-900"><%= @appointment.doctor&.name || "No asignado" %></dd>
            </div>

            <div class="rounded-2xl border border-gray-100 bg-gray-50 p-4 md:col-span-2">
              <dt class="text-sm font-medium text-gray-500">Fecha y hora</dt>
              <dd class="mt-1 text-base font-semibold leading-relaxed text-gray-900">
                <%= l(@appointment.start_date, format: :long, default: "") rescue "N/A" %>
              </dd>
            </div>
          </dl>
        </div>

        <!-- Resultados -->
        <div class="mb-8 border-t border-gray-200 pt-8">
          <h2 class="mb-4 text-lg font-bold text-gray-900 sm:text-xl flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Resultados de Estudios
          </h2>

          <% if @appointment.study_results.attached? %>
            <ul class="space-y-3">
              <% @appointment.study_results.each do |result| %>
                <li class="flex items-center justify-between rounded-xl border border-gray-200 bg-white p-4 shadow-sm hover:shadow-md transition">
                  <div class="flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-red-500" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-sm font-semibold text-gray-700 truncate max-w-[200px] sm:max-w-xs"><%= result.filename %></span>
                  </div>
                  <%= link_to "Descargar", rails_blob_path(result, disposition: "attachment"), class: "inline-flex items-center justify-center rounded-lg bg-blue-50 px-3 py-2 text-sm font-semibold text-blue-700 hover:bg-blue-100 transition" %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <div class="rounded-2xl border border-dashed border-gray-300 bg-gray-50 px-6 py-10 text-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
              </svg>
              <h3 class="mt-2 text-sm font-semibold text-gray-900">Sin estudios</h3>
              <p class="mt-1 text-sm text-gray-500">No hay resultados disponibles por el momento.</p>
            </div>
          <% end %>
        </div>

        <!-- Zona de Peligro / Cancelación -->
        <% unless @appointment.canceled_by_admin? || @appointment.canceled_by_client? || @appointment.completed? || @appointment.no_show? %>
          <div class="mb-8 border-t border-gray-200 pt-8 mt-4">
            <h3 class="text-lg font-bold text-gray-900 mb-4 sm:text-xl">Cancelar Cita</h3>
            <div class="rounded-2xl border border-red-200 bg-red-50 p-5">
              <div class="flex items-start gap-3 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-6 w-6 flex-shrink-0 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                <div class="text-sm leading-relaxed text-red-900">
                  <strong class="block font-bold">¿Necesitas cancelar tu cita?</strong>
                  Al cancelar, el horario se liberará para otras personas. Esta acción no se puede deshacer.
                </div>
              </div>
              <div class="flex">
                <%= button_to "Confirmar cancelación",
                      appointment_path(@appointment),
                      method: :delete,
                      form: {
                        data: {
                          turbo_confirm: "¿Estás completamente seguro de que deseas cancelar?"
                        }
                      },
                      class: "inline-flex w-full sm:w-auto items-center justify-center rounded-xl bg-red-600 px-5 py-3 text-sm font-bold text-white shadow-sm transition hover:bg-red-700" %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Actions -->
        <div class="mt-8 border-t border-gray-100 pt-6 flex justify-center">
          <%= link_to "Volver al inicio",
                root_path,
                class: "inline-flex items-center justify-center rounded-xl border border-gray-300 bg-white px-6 py-3 text-sm font-semibold text-gray-700 shadow-sm transition hover:bg-gray-50 focus:outline-none focus:ring-4 focus:ring-gray-100" %>
        </div>
      </div>
    </div>
  </div>
</div>