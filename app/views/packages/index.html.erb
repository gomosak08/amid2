<div class="min-h-[70vh] bg-gradient-to-b from-blue-50 via-white to-white">
  <div class="w-full py-10">
    
    <!-- Encabezado -->
    <div class="overflow-hidden rounded-[28px] border border-gray-200 bg-white shadow-xl shadow-blue-100/40">
      <div class="relative overflow-hidden bg-gradient-to-r from-blue-600 to-cyan-500 px-6 py-8 text-white sm:px-10 sm:py-10">
        
        <div class="absolute inset-0 opacity-10">
          <div class="absolute -right-8 -top-8 h-32 w-32 rounded-full bg-white"></div>
          <div class="absolute -bottom-10 -left-10 h-40 w-40 rounded-full bg-white"></div>
        </div>

        <div class="relative mx-auto max-w-4xl text-center">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-white/15 backdrop-blur-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h10M4 18h10" />
            </svg>
          </div>

          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl lg:text-4xl">
            Paquetes
          </h2>

          <p class="mt-3 text-sm leading-6 text-blue-50 sm:text-base">
            Explora nuestros paquetes disponibles y agenda tu cita de manera rápida y sencilla.
          </p>
        </div>
      </div>

      <!-- Grid de paquetes -->
      <div class="px-6 py-10 sm:px-10">
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4">
          
          <% @packages.where(kind: "paquete").each do |package| %>
            <article
              class="group flex h-full flex-col overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl"
              data-controller="toggle-description"
            >

              <% if package.image.present? %>
                <div
                  data-action="click->toggle-description#toggle"
                  class="cursor-pointer overflow-hidden bg-gray-100"
                >
                  <%= image_tag package.image,
                        alt: package.name,
                        class: "h-60 w-full object-cover transition duration-500 group-hover:scale-105" %>
                </div>
              <% else %>
                <div class="flex h-60 items-center justify-center bg-gray-50 text-sm text-gray-400">
                  Sin imagen disponible
                </div>
              <% end %>

              <div class="flex flex-1 flex-col p-6">
                <div class="mb-3 flex items-start justify-between gap-3">
                  <div class="min-w-0 flex-1">
                    <h3 class="text-lg font-bold leading-tight text-gray-900">
                      <%= link_to package.name,
                            package_path(package),
                            class: "block break-words transition hover:text-blue-600" %>
                    </h3>
                  </div>

                  <button
                    type="button"
                    data-action="click->toggle-description#toggle"
                    class="shrink-0 rounded-lg px-3 py-1.5 text-xs font-semibold text-gray-500 transition hover:bg-blue-50 hover:text-blue-600"
                  >
                    Detalles
                  </button>
                </div>

                <div class="mb-4 flex flex-wrap items-center gap-2">
                  <span class="inline-flex items-center rounded-full bg-blue-50 px-3 py-1 text-sm font-semibold text-blue-700">
                    <%= mxn(package.price) %>
                  </span>

                  <% if package.duration.present? %>
                    <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-700">
                      <%= package.duration %>
                    </span>
                  <% end %>
                </div>

                <p class="mb-4 text-sm leading-6 text-gray-600">
                  <%= truncate(package.description.presence || "Sin descripción disponible.", length: 110) %>
                </p>

                <div
                  data-toggle-description-target="description"
                  class="hidden mb-4 rounded-2xl border border-gray-100 bg-gray-50 px-4 py-3 text-sm leading-relaxed text-gray-700"
                >
                  <%= simple_format(
                        package.description.presence || "Sin descripción disponible.",
                        {},
                        wrapper_tag: "p",
                        class: "m-0"
                      ) %>
                </div>

                <div class="mt-auto pt-2">
                  <%= link_to "Agendar cita",
                      new_appointment_path(package_id: package.id),
                      class: "inline-flex w-full items-center justify-center rounded-2xl bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700",
                      data: { turbo: false } %>
                </div>
              </div>
            </article>

          <% end %>

        </div>
      </div>
    </div>
  </div>
</div>
